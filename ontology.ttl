:MiningAndMetalsSector rdf:type owl:NamedIndividual ,
                                :Sector ;
                       :assessedUnder :TNFD ;
                       :hasSectorClassification :GICS ;
                       rdfs:label "Mining and Metals Sector"@en ;
                       <http://www.w3.org/2004/02/skos/core#altLabel> "Materials (GICS)"@en .


###  https://w3id.org/biodivrisK-onto#OBISData
:OBISData rdf:type owl:NamedIndividual ,
                   :BiodiversityDataSource ;
          rdfs:comment "Ocean Biodiversity Information System — primary open source for marine species occurrence records. Under-representation of Caribbean marine ecosystems."@en ;
          rdfs:label "OBIS Marine Data"@en ;
          <https://schema.org/url> <https://obis.org> .


