@prefix : <https://w3id.org/biodivrisK-onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/biodivrisK-onto#> .

<https://w3id.org/biodivrisK-onto> rdf:type owl:Ontology ;
                                    owl:versionIRI <https://w3id.org/biodivrisK-onto/0.1.0> ;
                                    owl:imports <https://w3id.org/biodivrisK-onto/0.1.0> ;
                                    <http://purl.org/dc/terms/created> "2026-07-13"^^xsd:date ,
                                                                       "2026-07-21"^^xsd:date ;
                                    <http://purl.org/dc/terms/creator> _:genid1 ,
                                                                       _:genid2 ,
                                                                       _:genid3 ;
                                    <http://purl.org/dc/terms/description> "BiodivRisk-Onto provides a formal OWL 2 DL representation of the semantic relations between four international biodiversity risk disclosure frameworks — TNFD, CSRD/ESRS E4, SBTN and GRI 101 — with particular attention to the data gaps arising from GBIF/OBIS sampling bias in Latin America and the Caribbean (LAC)."@en ,
                                                                           "Extension of v0.1.0 with organizational, geographic, and evaluation modules, populated with real-world instances from the Santander Peru and CEBDS Brazil case studies."@en ;
                                    <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                    <http://purl.org/dc/terms/title> "BiodivRisk-Onto v0.2.0: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks"@en ,
                                                                     "BiodivRisk-Onto: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks"@en ;
                                    <http://purl.org/vocab/vann/preferredNamespacePrefix> "bro" ;
                                    <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/biodivrisK-onto#" ;
                                    rdfs:comment "Prototype v0.1.0. Developed as part of the paper submitted to AMW 2026."@en ;
                                    rdfs:seeAlso <https://github.com/marcosdzarate/biorisk-ai> ,
                                                 <https://github.com/marcosdzarate/biorisk-ai/tree/main/ontology> ;
                                    owl:versionInfo "0.1.0" ,
                                                    "0.2.0" .

_:genid1 rdf:type <https://schema.org/Person> ;
          <https://schema.org/affiliation> "CESIMAR-CONICET, Puerto Madryn, Argentina" ;
          <https://schema.org/name> "Marcos Daniel Zárate" ;
          <https://schema.org/url> <https://orcid.org/0000-0001-8851-8602> .

_:genid2 rdf:type <https://schema.org/Person> ;
          <https://schema.org/affiliation> "CESIMAR-CONICET, Puerto Madryn, Argentina" ;
          <https://schema.org/name> "Gustavo Nuñez" .

_:genid3 rdf:type <https://schema.org/Person> ;
          <https://schema.org/affiliation> "CESIMAR-CONICET, Puerto Madryn, Argentina" ;
          <https://schema.org/name> "Marcos Daniel Zárate" ;
          <https://schema.org/url> <https://orcid.org/0000-0001-8851-8602> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
<http://www.w3.org/2004/02/skos/core#note> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasAssociatedWith
<http://www.w3.org/ns/prov#wasAssociatedWith> rdf:type owl:AnnotationProperty .


###  https://schema.org/affiliation
<https://schema.org/affiliation> rdf:type owl:AnnotationProperty .


###  https://schema.org/name
<https://schema.org/name> rdf:type owl:AnnotationProperty .


###  https://schema.org/url
<https://schema.org/url> rdf:type owl:AnnotationProperty .


###  https://w3id.org/biodivrisK-onto#hasBridgingCondition
:hasBridgingCondition rdf:type owl:AnnotationProperty ;
                      rdfs:comment "Documents the explicit assumption under which a lossy approximation between two incommensurable concepts is admissible. Required on every bro:incommensurableWith assertion."@en ;
                      rdfs:label "has bridging condition"@en .


###  https://w3id.org/biodivrisK-onto#unit
:unit rdf:type owl:AnnotationProperty ;
      rdfs:comment "Unit of measurement associated with a metric."@en ;
      rdfs:label "unit"@en .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/biodivrisK-onto#affectsFramework
:affectsFramework rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataGap ;
                  rdfs:range :DisclosureFramework ;
                  rdfs:comment "Relates a data gap to the framework(s) whose assessments are affected."@en ;
                  rdfs:label "affects framework"@en .


###  https://w3id.org/biodivrisK-onto#affectsRiskAssessment
:affectsRiskAssessment rdf:type owl:ObjectProperty ;
                       rdfs:domain :MaterialityBoundary ;
                       rdfs:range :PhysicalRisk ;
                       rdfs:comment "Relates a materiality boundary gap to the type of physical risk whose assessment is affected."@en ;
                       rdfs:label "affects risk assessment"@en .


###  https://w3id.org/biodivrisK-onto#appliesFramework
:appliesFramework rdf:type owl:ObjectProperty ;
                  rdfs:domain :Organization ;
                  rdfs:range :DisclosureFramework ;
                  rdfs:comment "Relates an organization to a disclosure framework it applies or is subject to."@en ;
                  rdfs:label "applies framework"@en .


###  https://w3id.org/biodivrisK-onto#assessedUnder
:assessedUnder rdf:type owl:ObjectProperty ;
               rdfs:domain :Sector ;
               rdfs:range :DisclosureFramework ;
               rdfs:comment "Relates a sector or portfolio to the disclosure framework under which it was assessed for materiality."@en ;
               rdfs:label "assessed under"@en .


###  https://w3id.org/biodivrisK-onto#complements
:complements rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ;
             rdfs:domain owl:Class ;
             rdfs:range owl:Class ;
             rdfs:comment "Two framework concept classes that address distinct, jointly-required facets of one assessment. Licenses composition of evidence, not substitution. Symmetric."@en ;
             rdfs:label "complements"@en .


###  https://w3id.org/biodivrisK-onto#coveredByFramework
:coveredByFramework rdf:type owl:ObjectProperty ;
                    rdfs:domain :FrameworkConcept ;
                    rdfs:range :DisclosureFramework ;
                    rdfs:comment "Relates a framework concept to the frameworks that include or address it."@en ;
                    rdfs:label "covered by framework"@en .


###  https://w3id.org/biodivrisK-onto#coversRequirement
:coversRequirement rdf:type owl:ObjectProperty ;
                   rdfs:domain :InternalPolicy ;
                   rdfs:range :DisclosureRequirement ;
                   rdfs:comment "Relates an internal policy to the disclosure requirements of external frameworks that it partially or fully covers."@en ;
                   rdfs:label "covers requirement"@en .


###  https://w3id.org/biodivrisK-onto#definedBy
:definedBy rdf:type owl:ObjectProperty ;
           rdfs:domain :FrameworkConcept ;
           rdfs:range :DisclosureFramework ;
           rdfs:comment "Relates a framework concept class to the framework that defines it."@en ;
           rdfs:label "defined by"@en .


###  https://w3id.org/biodivrisK-onto#hasAmbiguity
:hasAmbiguity rdf:type owl:ObjectProperty ;
              rdfs:domain :IndustrialClassification ;
              rdfs:range :SemanticAmbiguity ;
              rdfs:label "has ambiguity"@en .


###  https://w3id.org/biodivrisK-onto#hasDataGapIn
:hasDataGapIn rdf:type owl:ObjectProperty ;
              rdfs:domain :DisclosureFramework ;
              rdfs:range :Biome ;
              rdfs:comment "Relates a disclosure framework to a biome where its data requirements cannot be met due to GBIF/OBIS sampling bias."@en ;
              rdfs:label "has data gap in"@en .


###  https://w3id.org/biodivrisK-onto#hasDataSufficiency
:hasDataSufficiency rdf:type owl:ObjectProperty ;
                    rdfs:domain :DataSufficiencyAssessment ;
                    rdfs:range :Biome ;
                    rdfs:label "has data sufficiency"@en .


###  https://w3id.org/biodivrisK-onto#hasEvaluationResult
:hasEvaluationResult rdf:type owl:ObjectProperty ;
                     rdfs:domain :LEAPAssessment ;
                     rdfs:range :MaterialityResult ;
                     rdfs:label "has evaluation result"@en .


###  https://w3id.org/biodivrisK-onto#hasInformationLoss
:hasInformationLoss rdf:type owl:ObjectProperty ;
                    rdfs:domain owl:Class ;
                    rdfs:range :InformationLoss ;
                    rdfs:comment "Documents what information is lost when converting between two incommensurable framework concepts."@en ;
                    rdfs:label "has information loss"@en .


###  https://w3id.org/biodivrisK-onto#hasMaterialityApproach
:hasMaterialityApproach rdf:type owl:ObjectProperty ;
                        rdfs:domain :DisclosureFramework ;
                        rdfs:range :MaterialityApproach ;
                        rdfs:label "has materiality approach"@en .


###  https://w3id.org/biodivrisK-onto#hasPortfolioSector
:hasPortfolioSector rdf:type owl:ObjectProperty ;
                    rdfs:domain :FinancialInstitution ;
                    rdfs:range :Sector ;
                    rdfs:comment "Relates a financial institution to an economic sector represented in its credit or investment portfolio."@en ;
                    rdfs:label "has portfolio sector"@en .


###  https://w3id.org/biodivrisK-onto#hasScale
:hasScale rdf:type owl:ObjectProperty ;
          rdfs:domain :MaterialityApproach ;
          rdfs:range :QuantitativeMaterialityScale ;
          rdfs:label "has scale"@en .


###  https://w3id.org/biodivrisK-onto#hasSectorClassification
:hasSectorClassification rdf:type owl:ObjectProperty ;
                         rdfs:domain :Sector ;
                         rdfs:range :IndustrialClassification ;
                         rdfs:label "has sector classification"@en .


###  https://w3id.org/biodivrisK-onto#incommensurableWith
:incommensurableWith rdf:type owl:ObjectProperty ,
                              owl:SymmetricProperty ;
                     rdfs:domain owl:Class ;
                     rdfs:range owl:Class ;
                     rdfs:comment "Two framework concept classes for which no truth-preserving mapping exists due to different measurement units, materiality boundaries or epistemic commitments. Every assertion MUST carry bro:hasBridgingCondition. Symmetric."@en ;
                     rdfs:label "incommensurable with"@en .


###  https://w3id.org/biodivrisK-onto#informsTargetSetting
:informsTargetSetting rdf:type owl:ObjectProperty ;
                      rdfs:domain :LEAPAssessment ;
                      rdfs:range :SBTNAR3TTarget ;
                      rdfs:comment "A directed property: the output of a LEAP assessment informs the science-based target-setting process of SBTN AR3T."@en ;
                      rdfs:label "informs target setting"@en .


###  https://w3id.org/biodivrisK-onto#mappableTo
:mappableTo rdf:type owl:ObjectProperty ;
            rdfs:domain :IndustrialClassification ;
            rdfs:range :IndustrialClassification ;
            rdfs:comment "A lossy correspondence between two industrial classification standards requiring manual effort and producing semantic ambiguity."@en ;
            rdfs:label "mappable to"@en .


###  https://w3id.org/biodivrisK-onto#operatesInBiome
:operatesInBiome rdf:type owl:ObjectProperty ;
                 rdfs:domain :Organization ;
                 rdfs:range :Biome ;
                 rdfs:label "operates in biome"@en .


###  https://w3id.org/biodivrisK-onto#operatesInCountry
:operatesInCountry rdf:type owl:ObjectProperty ;
                   rdfs:domain :Organization ;
                   rdfs:range :Country ;
                   rdfs:label "operates in country"@en .


###  https://w3id.org/biodivrisK-onto#prioritisesSector
:prioritisesSector rdf:type owl:ObjectProperty ;
                   rdfs:domain :MaterialityResult ;
                   rdfs:range :Sector ;
                   rdfs:label "prioritises sector"@en .


###  https://w3id.org/biodivrisK-onto#requiresDataFrom
:requiresDataFrom rdf:type owl:ObjectProperty ;
                  rdfs:domain :LEAPAssessment ;
                  rdfs:range :BiodiversityDataSource ;
                  rdfs:label "requires data from"@en .


###  https://w3id.org/biodivrisK-onto#requiresInputFrom
:requiresInputFrom rdf:type owl:ObjectProperty ;
                   owl:inverseOf :informsTargetSetting ;
                   rdfs:domain :SBTNAR3TTarget ;
                   rdfs:range :LEAPAssessment ;
                   rdfs:comment "A directed property: SBTN AR3T target setting requires location and materiality data produced by a TNFD LEAP assessment."@en ;
                   rdfs:label "requires input from"@en .


###  https://w3id.org/biodivrisK-onto#usesClassification
:usesClassification rdf:type owl:ObjectProperty ;
                    rdfs:domain :Organization ;
                    rdfs:range :IndustrialClassification ;
                    rdfs:label "uses classification"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/ENVO_00000428
<http://purl.obolibrary.org/obo/ENVO_00000428> rdf:type owl:Class ;
                                               owl:equivalentClass :Biome .


###  http://www.opengis.net/ont/geosparql#Feature
<http://www.opengis.net/ont/geosparql#Feature> rdf:type owl:Class .


###  http://www.w3.org/2002/07/owl#Class
owl:Class rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  https://schema.org/BankOrCreditUnion
<https://schema.org/BankOrCreditUnion> rdf:type owl:Class .


###  https://schema.org/Country
<https://schema.org/Country> rdf:type owl:Class .


###  https://schema.org/Organization
<https://schema.org/Organization> rdf:type owl:Class .


###  https://schema.org/Person
<https://schema.org/Person> rdf:type owl:Class .


###  https://w3id.org/biodivrisK-onto#BiodiversityDataSource
:BiodiversityDataSource rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                        rdfs:comment "An open or proprietary data source used to obtain species occurrence, ecosystem integrity or water risk data during a LEAP assessment (e.g., GBIF, OBIS, ENCORE, Global Forest Watch, WRI Aqueduct, IBAT)."@en ;
                        rdfs:label "Biodiversity Data Source"@en .


###  https://w3id.org/biodivrisK-onto#Biome
:Biome rdf:type owl:Class ;
       rdfs:comment "A major ecological zone characterized by distinctive climate, vegetation and biodiversity. Reuses ENVO biome concept (ENVO:00000428). In LAC, biomes are megadiverse and systematically under-sampled in GBIF/OBIS."@en ;
       rdfs:label "Biome"@en .


###  https://w3id.org/biodivrisK-onto#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ,
                         <https://schema.org/Country> ;
         rdfs:comment "A sovereign country where a financial institution operates or has portfolio exposure."@en ;
         rdfs:label "Country"@en .


###  https://w3id.org/biodivrisK-onto#DataGap
:DataGap rdf:type owl:Class ;
         rdfs:comment "A systematic absence or insufficiency of biodiversity occurrence data limiting the reliability of framework-based risk assessments in a given geographic area, taxonomic group or ecosystem type."@en ;
         rdfs:label "Data Gap"@en .


###  https://w3id.org/biodivrisK-onto#DataSufficiencyAssessment
:DataSufficiencyAssessment rdf:type owl:Class ;
                           rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                           rdfs:comment "An evaluation of whether available biodiversity data from sources such as GBIF and OBIS are sufficient to meet the information requirements of a given disclosure framework for a specific biome, sector and location. Quantifies data gaps arising from geographic and taxonomic sampling bias."@en ;
                           rdfs:label "Data Sufficiency Assessment"@en .


###  https://w3id.org/biodivrisK-onto#DisclosureFramework
:DisclosureFramework rdf:type owl:Class ;
                     rdfs:comment "A regulatory or voluntary framework requiring organisations to assess and disclose their nature-related impacts, dependencies, risks and opportunities."@en ;
                     rdfs:label "Disclosure Framework"@en .


###  https://w3id.org/biodivrisK-onto#DisclosureRequirement
:DisclosureRequirement rdf:type owl:Class ;
                       rdfs:comment "A specific disclosure requirement within a framework, at the level of a recommended disclosure, datapoint or metric (e.g., TNFD Strategy D, ESRS E4-5, GRI 101-6)."@en ;
                       rdfs:label "Disclosure Requirement"@en .


###  https://w3id.org/biodivrisK-onto#ESRSBiodiversitySensitiveArea
:ESRSBiodiversitySensitiveArea rdf:type owl:Class ;
                               owl:equivalentClass :GRIOperationsAdjacentProtectedAreas ;
                               rdfs:subClassOf :FrameworkConcept ,
                                               :TNFDPriorityLocation .


###  https://w3id.org/biodivrisK-onto#ESRSDoubleMateriality
:ESRSDoubleMateriality rdf:type owl:Class ;
                       rdfs:subClassOf :MaterialityBoundary .


###  https://w3id.org/biodivrisK-onto#ESRSLandUseDatapoint
:ESRSLandUseDatapoint rdf:type owl:Class ;
                      owl:equivalentClass :TNFDLandUseChangeMetric ;
                      rdfs:subClassOf :Metric .


###  https://w3id.org/biodivrisK-onto#ESRSMaterialImpactDependency
:ESRSMaterialImpactDependency rdf:type owl:Class ;
                              owl:equivalentClass :TNFDImpactDependency ;
                              rdfs:subClassOf :FrameworkConcept .


###  https://w3id.org/biodivrisK-onto#FinancialInstitution
:FinancialInstitution rdf:type owl:Class ;
                      rdfs:subClassOf <https://schema.org/BankOrCreditUnion> ,
                                      :Organization ;
                      rdfs:comment "A bank, investment fund, insurance company or other financial institution whose portfolio exposure to nature-related risks is assessed through biodiversity risk frameworks."@en ;
                      rdfs:label "Financial Institution"@en .


###  https://w3id.org/biodivrisK-onto#FrameworkConcept
:FrameworkConcept rdf:type owl:Class ;
                  rdfs:comment "A concept, disclosure requirement, indicator or metric defined within a disclosure framework. Subclasses represent specific concepts; individuals of this class are not intended."@en ;
                  rdfs:label "Framework Concept"@en .


###  https://w3id.org/biodivrisK-onto#GRIImpactMateriality
:GRIImpactMateriality rdf:type owl:Class ;
                      rdfs:subClassOf :MaterialityBoundary .


###  https://w3id.org/biodivrisK-onto#GRIManagementApproach
:GRIManagementApproach rdf:type owl:Class ;
                       rdfs:subClassOf :FrameworkConcept .


###  https://w3id.org/biodivrisK-onto#GRIOperationsAdjacentProtectedAreas
:GRIOperationsAdjacentProtectedAreas rdf:type owl:Class ;
                                     rdfs:subClassOf :FrameworkConcept ,
                                                     :TNFDPriorityLocation .


###  https://w3id.org/biodivrisK-onto#GeographicSamplingBias
:GeographicSamplingBias rdf:type owl:Class ;
                        rdfs:subClassOf :DataGap ;
                        rdfs:comment "Systematic under-representation of species occurrences in GBIF/OBIS records for specific geographic regions."@en ;
                        rdfs:label "Geographic Sampling Bias"@en .


###  https://w3id.org/biodivrisK-onto#IndustrialClassification
:IndustrialClassification rdf:type owl:Class ;
                          rdfs:comment "A standard system for classifying economic activities into sectors and subsectors (e.g., GICS, CNAE, CIIU, SASB/SICS). Different standards may not be mutually translatable without ambiguity."@en ;
                          rdfs:label "Industrial Classification Standard"@en .


###  https://w3id.org/biodivrisK-onto#InformationLoss
:InformationLoss rdf:type owl:Class ;
                 rdfs:comment "The loss of material information that occurs when translating a disclosure or target from one framework to another under an incommensurability relationship. Complements bro:hasBridgingCondition by documenting what is lost, not just under what conditions the conversion is admissible."@en ;
                 rdfs:label "Information Loss"@en .


###  https://w3id.org/biodivrisK-onto#InternalPolicy
:InternalPolicy rdf:type owl:Class ;
                rdfs:comment "An organization's internal policy for managing environmental, social, climate or nature-related risks (e.g., an ESCC policy). May partially cover requirements of external disclosure frameworks."@en ;
                rdfs:label "Internal Policy"@en .


###  https://w3id.org/biodivrisK-onto#LEAPAssessment
:LEAPAssessment rdf:type owl:Class ;
                rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                rdfs:comment "A structured assessment following the TNFD LEAP methodology (Locate, Evaluate, Assess, Prepare), conducted by an organization to identify and assess its nature-related dependencies, impacts, risks and opportunities. Connects the organization, frameworks applied, sectors evaluated, biomes, data sources and gaps identified."@en ;
                rdfs:label "LEAP Assessment"@en .


###  https://w3id.org/biodivrisK-onto#MaterialityApproach
:MaterialityApproach rdf:type owl:Class ;
                     rdfs:comment "A methodological approach for determining which nature-related impacts, risks and opportunities are material and must be disclosed. Different frameworks apply different approaches (financial, impact, or double materiality) that are not mutually equivalent."@en ;
                     rdfs:label "Materiality Approach"@en .


###  https://w3id.org/biodivrisK-onto#MaterialityBoundary
:MaterialityBoundary rdf:type owl:Class ;
                     rdfs:comment "The scope and criteria used by a framework to determine which impacts and financial effects are material and must be disclosed."@en ;
                     rdfs:label "Materiality Boundary"@en .


###  https://w3id.org/biodivrisK-onto#MaterialityResult
:MaterialityResult rdf:type owl:Class ;
                   rdfs:comment "The output of a materiality assessment — a ranked or scored set of sectors, locations or impacts identified as material under a specific framework and approach."@en ;
                   rdfs:label "Materiality Result"@en .


###  https://w3id.org/biodivrisK-onto#Metric
:Metric rdf:type owl:Class ;
        rdfs:subClassOf :FrameworkConcept ;
        rdfs:comment "A quantitative or semi-quantitative indicator expressed in specific units or using a defined measurement approach."@en ;
        rdfs:label "Metric"@en .


###  https://w3id.org/biodivrisK-onto#Organization
:Organization rdf:type owl:Class ;
              rdfs:subClassOf <https://schema.org/Organization> ;
              rdfs:comment "An organization that applies one or more biodiversity risk disclosure frameworks to assess its nature-related dependencies, impacts, risks and opportunities."@en ;
              rdfs:label "Organization"@en .


###  https://w3id.org/biodivrisK-onto#PhysicalRisk
:PhysicalRisk rdf:type owl:Class ;
              rdfs:comment "A nature-related physical risk arising from the degradation of ecosystems or natural capital, including water stress, ecosystem collapse, loss of pollination, erosion or flooding. Corresponds to TNFD and ESRS physical risk category."@en ;
              rdfs:label "Physical Risk"@en .


###  https://w3id.org/biodivrisK-onto#Portfolio
:Portfolio rdf:type owl:Class ;
           rdfs:comment "A credit or investment portfolio of a financial institution, composed of assets across multiple economic sectors and geographic locations."@en ;
           rdfs:label "Portfolio"@en .


###  https://w3id.org/biodivrisK-onto#PriorityLocation
:PriorityLocation rdf:type owl:Class ;
                  rdfs:subClassOf :FrameworkConcept .


###  https://w3id.org/biodivrisK-onto#QualitativeMaterialityScale
:QualitativeMaterialityScale rdf:type owl:Class ;
                             rdfs:subClassOf :MaterialityApproach ;
                             rdfs:comment "A narrative or categorical approach to assessing materiality of nature-related impacts, without a fixed numerical scale (e.g., GRI 101 impact materiality approach)."@en ;
                             rdfs:label "Qualitative Materiality Scale"@en .


###  https://w3id.org/biodivrisK-onto#QuantitativeMaterialityScale
:QuantitativeMaterialityScale rdf:type owl:Class ;
                              rdfs:subClassOf :MaterialityApproach ;
                              rdfs:comment "A numerical scale used to score materiality of nature-related impacts and dependencies (e.g., ENCORE scale 3-9: very low=3, low=4.5, medium=6, high=7.5, very high=9)."@en ;
                              rdfs:label "Quantitative Materiality Scale"@en .


###  https://w3id.org/biodivrisK-onto#SBTNAR3TTarget
:SBTNAR3TTarget rdf:type owl:Class ;
                rdfs:subClassOf :FrameworkConcept .


###  https://w3id.org/biodivrisK-onto#SBTNMeanSpeciesAbundance
:SBTNMeanSpeciesAbundance rdf:type owl:Class ;
                          rdfs:subClassOf :Metric .


###  https://w3id.org/biodivrisK-onto#Sector
:Sector rdf:type owl:Class ;
        rdfs:comment "An economic sector associated with potential impacts and dependencies on nature, classifiable under international standards such as GICS or SASB/SICS."@en ;
        rdfs:label "Economic Sector"@en .


###  https://w3id.org/biodivrisK-onto#SemanticAmbiguity
:SemanticAmbiguity rdf:type owl:Class ;
                   rdfs:comment "A documented case of semantic ambiguity in the correspondence between two industrial classification standards, where a category in one standard maps to multiple non-equivalent categories in another, or vice versa."@en ;
                   rdfs:label "Semantic Ambiguity"@en .


###  https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality
:TNFDEnterpriseMateriality rdf:type owl:Class ;
                           rdfs:subClassOf :MaterialityBoundary .


###  https://w3id.org/biodivrisK-onto#TNFDImpactDependency
:TNFDImpactDependency rdf:type owl:Class ;
                      rdfs:subClassOf :FrameworkConcept .


###  https://w3id.org/biodivrisK-onto#TNFDLandUseChangeMetric
:TNFDLandUseChangeMetric rdf:type owl:Class ;
                         rdfs:subClassOf :Metric .


###  https://w3id.org/biodivrisK-onto#TNFDPriorityLocation
:TNFDPriorityLocation rdf:type owl:Class ;
                      rdfs:subClassOf :FrameworkConcept .


###  https://w3id.org/biodivrisK-onto#TaxonomicSamplingBias
:TaxonomicSamplingBias rdf:type owl:Class ;
                       rdfs:subClassOf :DataGap ;
                       rdfs:comment "Systematic over-representation of certain taxonomic groups (e.g. birds, vascular plants) in open biodiversity databases."@en ;
                       rdfs:label "Taxonomic Sampling Bias"@en .


###  https://w3id.org/biodivrisK-onto#WaterStressRisk
:WaterStressRisk rdf:type owl:Class ;
                 rdfs:subClassOf :PhysicalRisk ;
                 rdfs:comment "Physical risk arising from insufficient availability or quality of freshwater resources, particularly relevant for mining and agricultural sectors in the Andes. Identified as material dependency in the Santander Peru LEAP assessment (L2)."@en ;
                 rdfs:label "Water Stress Risk"@en .


#################################################################
#    Individuals
#################################################################

###  https://w3id.org/biodivrisK-onto#AgriculturalProductsSector
:AgriculturalProductsSector rdf:type owl:NamedIndividual ,
                                     :Sector ;
                            :assessedUnder :TNFD ;
                            :hasSectorClassification :GICS ;
                            rdfs:label "Agricultural Products Sector"@en .


###  https://w3id.org/biodivrisK-onto#Amazonia
:Amazonia rdf:type owl:NamedIndividual ,
                   :Biome ;
          rdfs:comment "Largest tropical rainforest biome globally. Under-sampled in GBIF particularly for invertebrates and cryptic taxa. Relevant to both Santander Peru and CEBDS Brazil cases."@en ;
          rdfs:label "Amazonia Biome"@en .


###  https://w3id.org/biodivrisK-onto#AndeanDataGap
:AndeanDataGap rdf:type owl:NamedIndividual ,
                        :GeographicSamplingBias ;
               :affectsFramework :ESRS_E4 ,
                                 :TNFD ;
               rdfs:comment "Documented under-sampling of species occurrence records in GBIF for the tropical Andes biome, including Peru. Bias towards roads, cities and protected area boundaries. Leads to false negatives in TNFD priority-location screening. Empirically documented in Santander Peru LEAP L3-L4 assessment."@en ;
               rdfs:label "Andean GBIF Data Gap"@en .


###  https://w3id.org/biodivrisK-onto#AndeanWaterStressRisk
:AndeanWaterStressRisk rdf:type owl:NamedIndividual ,
                                :WaterStressRisk ;
                       :affectsRiskAssessment :TNFDEnterpriseMateriality ;
                       rdfs:comment "Physical risk from insufficient freshwater availability in Andean mining and agricultural operations in Peru. Identified as a material dependency in Santander Peru LEAP L2: groundwater use and protection against flooding were the most material ecosystem service dependencies. High water stress zones identified via WRI Aqueduct in LEAP L4."@en ;
                       rdfs:label "Andean Water Stress Risk"@en .


###  https://w3id.org/biodivrisK-onto#AtlanticForest
:AtlanticForest rdf:type owl:NamedIndividual ,
                         :Biome ;
                rdfs:comment "Critical biodiversity hotspot — less than 29% of original cover remains. Among the most threatened biomes in the world. Relevant to CEBDS Brazil case."@en ;
                rdfs:label "Atlantic Forest Biome"@en ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "Mata Atlântica"@pt .


###  https://w3id.org/biodivrisK-onto#BNDES
:BNDES rdf:type owl:NamedIndividual ,
                :FinancialInstitution ;
       :appliesFramework :TNFD ;
       :operatesInCountry :Brazil ;
       :usesClassification :CNAE ;
       rdfs:label "BNDES"@en ;
       <http://www.w3.org/2004/02/skos/core#prefLabel> "Banco Nacional de Desenvolvimento Econômico e Social"@en ;
       <https://schema.org/url> <https://www.bndes.gov.br> .


###  https://w3id.org/biodivrisK-onto#Bradesco
:Bradesco rdf:type owl:NamedIndividual ,
                   :FinancialInstitution ;
          :appliesFramework :TNFD ;
          :operatesInCountry :Brazil ;
          :usesClassification :CNAE ;
          rdfs:label "Banco Bradesco"@en ;
          <https://schema.org/url> <https://www.bradesco.com.br> .


###  https://w3id.org/biodivrisK-onto#Brazil
:Brazil rdf:type owl:NamedIndividual ,
                 :Country ;
        rdfs:comment "Most megadiverse country globally, hosting 15-20% of world biodiversity across 6 biomes. Site of CEBDS TNFD pilot."@en ;
        rdfs:label "Brazil"@en .


###  https://w3id.org/biodivrisK-onto#CEBDSBrazilLocateAssessment
:CEBDSBrazilLocateAssessment rdf:type owl:NamedIndividual ,
                                      :LEAPAssessment ;
                             :hasEvaluationResult :CEBDSHeatmapResult ;
                             :informsTargetSetting :SBTNAR3TTargetInstance ;
                             :requiresDataFrom :ENCOREData ,
                                               :GBIFData ,
                                               :WRIAqueductData ;
                             rdfs:comment "Collective piloting of the TNFD LEAP Locate phase by 5 Brazilian financial institutions coordinated by CEBDS and technically led by EY, September 2023–September 2024. Source: CEBDS/EY (2024)."@en ;
                             rdfs:label "CEBDS Brazil TNFD Locate Phase Pilot"@en ;
                             <http://www.w3.org/ns/prov#wasAssociatedWith> :BNDES ,
                                                                           :Bradesco ,
                                                                           :Caixa ,
                                                                           :ItauUnibanco ,
                                                                           :SantanderBrasil .


###  https://w3id.org/biodivrisK-onto#CEBDSHeatmapResult
:CEBDSHeatmapResult rdf:type owl:NamedIndividual ,
                             :MaterialityResult ;
                    :prioritisesSector :ConsumerDiscretionarySector ,
                                       :ConsumerStaplesSector ,
                                       :IndustrialsSector ,
                                       :UtilitiesSector ;
                    rdfs:comment "Sectoral materiality ranking from the CEBDS Brazil LEAP pilot using ENCORE scores combined with loan volume and number of clients data. Priority order: 1st Consumer Staples, 2nd Consumer Discretionary, 3rd Utilities, 4th Industrials."@en ;
                    rdfs:label "CEBDS Brazil Sector Heatmap Result"@en .


###  https://w3id.org/biodivrisK-onto#CIIU
:CIIU rdf:type owl:NamedIndividual ,
               :IndustrialClassification ;
      :hasAmbiguity :CIIUtoGICSAmbiguity ;
      :incommensurableWith :GICS ;
      :mappableTo :GICS ;
      rdfs:comment "UN international industrial classification used in Peru. Requires manual mapping to GICS/SASB for TNFD assessments."@en ;
      rdfs:label "CIIU"@en ;
      <http://www.w3.org/2004/02/skos/core#note> "CIIU (UN international classification used in Peru) does not map automatically to GICS or SASB/SICS sectors required for ENCORE-based TNFD assessments."@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Clasificación Industrial Internacional Uniforme"@en ;
      :hasBridgingCondition "A lossy correspondence requires manual alignment of CIIU codes to GICS and SASB/SICS sectors, with documentation of ambiguous cases. Performed by Santander Peru during LEAP L1 scoping."@en .


###  https://w3id.org/biodivrisK-onto#CIIUtoGICSAmbiguity
:CIIUtoGICSAmbiguity rdf:type owl:NamedIndividual ,
                              :SemanticAmbiguity ;
                     rdfs:comment "Documented semantic ambiguity in the CIIU-to-GICS/SASB mapping required for TNFD assessments in Peru. Peruvian CIIU categories require manual alignment with GICS and SASB/SICS sector definitions."@en ;
                     rdfs:label "CIIU to GICS Semantic Ambiguity"@en .


###  https://w3id.org/biodivrisK-onto#CIIUtoGICSMapping
:CIIUtoGICSMapping rdf:type owl:NamedIndividual ,
                            :SemanticAmbiguity ;
                   rdfs:comment "Manual sector correspondence developed by Santander Peru to align its CIIU-classified portfolio with GICS and SASB/SICS sectors required for ENCORE-based materiality screening."@en ;
                   rdfs:label "CIIU to GICS/SASB Mapping (Santander Peru)"@en .


###  https://w3id.org/biodivrisK-onto#CNAE
:CNAE rdf:type owl:NamedIndividual ,
               :IndustrialClassification ;
      :hasAmbiguity :CNAEtoGICSAmbiguity ;
      :incommensurableWith :GICS ;
      :mappableTo :GICS ;
      rdfs:comment "Brazilian national industrial classification used by financial institutions for portfolio reporting. Requires manual mapping to GICS for TNFD/ENCORE assessments."@en ;
      rdfs:label "CNAE"@en ;
      <http://www.w3.org/2004/02/skos/core#note> "CNAE (Brazilian national classification) and GICS (international standard used by ENCORE/TNFD) do not maintain a bijective correspondence. Multiple CNAE codes may map to one GICS sector and vice versa, generating semantic ambiguity in sector-level materiality assessments."@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Classificação Nacional de Atividades Econômicas"@en ;
      :hasBridgingCondition "A lossy correspondence is admissible when each CNAE code is manually mapped to the most representative GICS sector, with explicit documentation of multi-to-one and one-to-many correspondences. This mapping was performed by EY during the CEBDS Brazil LEAP pilot and required significant expert effort. The result is not automatically reversible."@en .


###  https://w3id.org/biodivrisK-onto#CNAEtoGICSAmbiguity
:CNAEtoGICSAmbiguity rdf:type owl:NamedIndividual ,
                              :SemanticAmbiguity ;
                     rdfs:comment "Documented semantic ambiguity in the CNAE-to-GICS mapping required for TNFD/ENCORE assessments. Brazilian CNAE categories do not maintain a bijective correspondence with GICS sectors — multiple CNAE codes may map to one GICS sector or vice versa. Required significant manual effort in the CEBDS Brazil pilot."@en ;
                     rdfs:label "CNAE to GICS Semantic Ambiguity"@en .


###  https://w3id.org/biodivrisK-onto#CNAEtoGICSMapping
:CNAEtoGICSMapping rdf:type owl:NamedIndividual ,
                            :SemanticAmbiguity ;
                   rdfs:comment "Manual sector correspondence developed during the CEBDS Brazil LEAP pilot to align portfolio reporting under CNAE with ENCORE/TNFD materiality assessment requiring GICS classification."@en ;
                   rdfs:label "CNAE to GICS Mapping (CEBDS Brazil)"@en .


###  https://w3id.org/biodivrisK-onto#Caixa
:Caixa rdf:type owl:NamedIndividual ,
                :FinancialInstitution ;
       :appliesFramework :TNFD ;
       :operatesInCountry :Brazil ;
       :usesClassification :CNAE ;
       rdfs:label "Caixa Econômica Federal"@en ;
       <https://schema.org/url> <https://www.caixa.gov.br> .


###  https://w3id.org/biodivrisK-onto#Cerrado
:Cerrado rdf:type owl:NamedIndividual ,
                  :Biome ;
         rdfs:comment "Brazilian tropical savanna — global biodiversity hotspot under severe agricultural pressure. 67.7% increase in deforestation in 2023. Under-sampled in GBIF for its specific endemic species."@en ;
         rdfs:label "Cerrado Biome"@en .


###  https://w3id.org/biodivrisK-onto#CerradoDataGap
:CerradoDataGap rdf:type owl:NamedIndividual ,
                         :GeographicSamplingBias ;
                :affectsFramework :ESRS_E4 ,
                                  :TNFD ;
                rdfs:comment "Documented under-sampling of species occurrence records in GBIF for the Cerrado biome, particularly invertebrates and endemic species. Documented in the CEBDS Brazil LEAP pilot as a challenge for L4 sensitive site identification."@en ;
                rdfs:label "Cerrado GBIF Data Gap"@en .


###  https://w3id.org/biodivrisK-onto#ConsumerDiscretionarySector
:ConsumerDiscretionarySector rdf:type owl:NamedIndividual ,
                                      :Sector ;
                             :assessedUnder :TNFD ;
                             :hasSectorClassification :GICS ;
                             rdfs:label "Consumer Discretionary Sector"@en .


###  https://w3id.org/biodivrisK-onto#ConsumerStaplesSector
:ConsumerStaplesSector rdf:type owl:NamedIndividual ,
                                :Sector ;
                       :assessedUnder :TNFD ;
                       :hasSectorClassification :GICS ;
                       rdfs:label "Consumer Staples Sector"@en ;
                       <http://www.w3.org/2004/02/skos/core#definition> "Companies involved in the production or sale of essential products, including food, beverages, tobacco, and hygiene products. Priority 1 in CEBDS Brazil heatmap."@en .


###  https://w3id.org/biodivrisK-onto#ENCOREData
:ENCOREData rdf:type owl:NamedIndividual ,
                     :BiodiversityDataSource ;
            rdfs:comment "Exploring Natural Capital Opportunities, Risks and Exposure — sector-level tool for screening nature-related impacts and dependencies. Uses a quantitative scale (3-9). Used in L2 by both Santander Peru and CEBDS Brazil."@en ;
            rdfs:label "ENCORE Tool"@en ;
            <https://schema.org/url> <https://encorenature.org> .


###  https://w3id.org/biodivrisK-onto#ENCOREMateriality
:ENCOREMateriality rdf:type owl:NamedIndividual ,
                            :QuantitativeMaterialityScale ;
                   :incommensurableWith :GRI101ImpactMateriality ;
                   rdfs:comment "ENCORE scores impacts and dependencies on a numerical scale: very low=3, low=4.5, medium=6, high=7.5, very high=9. Used by TNFD for sector-level screening."@en ;
                   rdfs:label "ENCORE Quantitative Materiality Scale"@en ;
                   <http://www.w3.org/2004/02/skos/core#note> "ENCORE applies a quantitative composite scale (3-9) aggregating dependencies and impacts by production process. GRI 101 applies qualitative impact materiality requiring stakeholder-informed severity assessment. The two approaches operate at different epistemic levels and use incompatible measurement units."@en ;
                   :hasBridgingCondition "A lossy approximation is admissible if ENCORE sector scores are supplemented with qualitative stakeholder evidence meeting GRI 101 impact severity criteria. The numerical scale (3-9) cannot be directly compared with GRI qualitative thresholds without explicit bridging assumptions documented per sector."@en .


###  https://w3id.org/biodivrisK-onto#ENCOREScale
:ENCOREScale rdf:type owl:NamedIndividual ,
                      :QuantitativeMaterialityScale ;
             rdfs:comment "ENCORE numerical scale where 3=very low, 4.5=low, 6=medium, 7.5=high, 9=very high dependency/impact. Used in CEBDS Brazil pilot to produce heatmap weighted by loan volume and client count."@en ;
             rdfs:label "ENCORE Scale 3-9"@en .


###  https://w3id.org/biodivrisK-onto#ESRSBiodiversitySensitiveArea
:ESRSBiodiversitySensitiveArea rdf:type owl:NamedIndividual ;
                               :definedBy :ESRS_E4 .


###  https://w3id.org/biodivrisK-onto#ESRSDoubleMateriality
:ESRSDoubleMateriality rdf:type owl:NamedIndividual ;
                       :definedBy :ESRS_E4 ;
                       :incommensurableWith :TNFDEnterpriseMateriality .


###  https://w3id.org/biodivrisK-onto#ESRSLandUseDatapoint
:ESRSLandUseDatapoint rdf:type owl:NamedIndividual ;
                      :definedBy :ESRS_E4 .


###  https://w3id.org/biodivrisK-onto#ESRSMaterialImpactDependency
:ESRSMaterialImpactDependency rdf:type owl:NamedIndividual ;
                              :definedBy :ESRS_E4 .


###  https://w3id.org/biodivrisK-onto#ESRS_E4
:ESRS_E4 rdf:type owl:NamedIndividual ,
                  :DisclosureFramework ;
         rdfs:label "CSRD/ESRS E4"@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "European Sustainability Reporting Standard on Biodiversity and Ecosystems"@en ;
         <https://schema.org/url> <https://www.efrag.org> .


###  https://w3id.org/biodivrisK-onto#GBIFData
:GBIFData rdf:type owl:NamedIndividual ,
                   :BiodiversityDataSource ;
          rdfs:comment "Global Biodiversity Information Facility — primary open source for terrestrial and freshwater species occurrence records. Exhibits geographic sampling bias in LAC: under-representation of Andes, Amazonia and Cerrado."@en ;
          rdfs:label "GBIF Occurrence Data"@en ;
          <https://schema.org/url> <https://www.gbif.org> .


###  https://w3id.org/biodivrisK-onto#GICS
:GICS rdf:type owl:NamedIndividual ,
               :IndustrialClassification ;
      :incommensurableWith :CIIU ,
                           :CNAE ;
      rdfs:comment "International sector classification used by ENCORE and TNFD for materiality assessment."@en ;
      rdfs:label "GICS"@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Global Industry Classification Standard"@en .


###  https://w3id.org/biodivrisK-onto#GRI101
:GRI101 rdf:type owl:NamedIndividual ,
                 :DisclosureFramework ;
        rdfs:label "GRI 101"@en ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "GRI 101: Biodiversity Standard 2024"@en ;
        <https://schema.org/url> <https://www.globalreporting.org> .


###  https://w3id.org/biodivrisK-onto#GRI101ImpactMateriality
:GRI101ImpactMateriality rdf:type owl:NamedIndividual ,
                                  :QualitativeMaterialityScale ;
                         :incommensurableWith :ENCOREMateriality ;
                         rdfs:comment "GRI 101 applies impact materiality: issues are material based on the significance of actual or potential impacts on people and the environment, assessed through stakeholder engagement and qualitative severity criteria."@en ;
                         rdfs:label "GRI 101 Impact Materiality"@en .


###  https://w3id.org/biodivrisK-onto#GRIImpactMateriality
:GRIImpactMateriality rdf:type owl:NamedIndividual ;
                      :definedBy :GRI101 .


###  https://w3id.org/biodivrisK-onto#GRIManagementApproach
:GRIManagementApproach rdf:type owl:NamedIndividual ;
                       :complements :TNFDImpactDependency ;
                       :definedBy :GRI101 ;
                       :incommensurableWith :SBTNAR3TTarget ,
                                            :SBTNMeanSpeciesAbundance .


###  https://w3id.org/biodivrisK-onto#GRIOperationsAdjacentProtectedAreas
:GRIOperationsAdjacentProtectedAreas rdf:type owl:NamedIndividual ;
                                     :definedBy :GRI101 .


###  https://w3id.org/biodivrisK-onto#GRIProtectedAreaKBA
:GRIProtectedAreaKBA rdf:type owl:NamedIndividual ,
                              :DisclosureRequirement ;
                     :definedBy :GRI101 ;
                     rdfs:comment "GRI 101-6: disclosure of operations located in, adjacent to, or containing protected areas or Key Biodiversity Areas."@en ;
                     rdfs:label "GRI 101 Operations in/adjacent to Protected Areas and KBAs"@en .


###  https://w3id.org/biodivrisK-onto#GlobalForestWatchData
:GlobalForestWatchData rdf:type owl:NamedIndividual ,
                                :BiodiversityDataSource ;
                       rdfs:comment "Near real-time forest monitoring platform used by Santander Peru in LEAP L3/L4 to map protected areas and KBAs across Peru."@en ;
                       rdfs:label "Global Forest Watch"@en ;
                       <https://schema.org/url> <https://www.globalforestwatch.org> .


