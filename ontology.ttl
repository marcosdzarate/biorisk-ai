:PriorityLocation rdf:type owl:NamedIndividual ;
                  :definedBy :TNFD .


###  https://w3id.org/biodivrisK-onto#SASB_SICS
:SASB_SICS rdf:type owl:NamedIndividual ,
                    :IndustrialClassification ;
           rdfs:label "SASB SICS"@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "SASB Sustainable Industry Classification System"@en .


###  https://w3id.org/biodivrisK-onto#SBTN
:SBTN rdf:type owl:NamedIndividual ,
               :DisclosureFramework ;
      rdfs:label "SBTN"@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Science Based Targets Network for Nature"@en ;
      <https://schema.org/url> <https://sciencebasedtargetsnetwork.org> .


###  https://w3id.org/biodivrisK-onto#SBTNAR3TTarget
:SBTNAR3TTarget rdf:type owl:NamedIndividual ;
                :coveredByFramework :SBTN ;
                :definedBy :SBTN ;
                :incommensurableWith :GRIManagementApproach .


###  https://w3id.org/biodivrisK-onto#SBTNAR3TTargetInstance
:SBTNAR3TTargetInstance rdf:type owl:NamedIndividual ,
                                 :SBTNAR3TTarget ;
                        :requiresInputFrom :CEBDSBrazilLocateAssessment ,
                                           :SantanderPeruL4Assessment ;
                        rdfs:comment "A science-based target following the SBTN AR3T hierarchy (Avoid, Reduce, Restore, Transform), as applicable to financial institutions assessing their portfolio exposure to nature loss. Requires LEAP assessment outputs as input for geographic and sectoral target-setting."@en ;
                        rdfs:label "SBTN AR3T Science-based Target"@en .


###  https://w3id.org/biodivrisK-onto#SBTNMeanSpeciesAbundance
:SBTNMeanSpeciesAbundance rdf:type owl:NamedIndividual ;
                          :coveredByFramework :SBTN ;
                          :definedBy :SBTN ;
                          :incommensurableWith :GRIManagementApproach .


###  https://w3id.org/biodivrisK-onto#SBTNtargetToGRIConversion
:SBTNtargetToGRIConversion rdf:type owl:NamedIndividual ,
                                    :InformationLoss ;
                           rdfs:comment "Information loss documented when converting an SBTN science-based target (measurable, time-bound, science-grounded) to a GRI 101 management approach disclosure (qualitative, policy-level). Lost information includes: (1) quantitative target value, (2) scientific baseline, (3) time horizon commitment, (4) verifiability. Bridging condition: the GRI management approach must explicitly commit to SBTN-compatible targets with verified science-based baselines."@en ;
                           rdfs:label "SBTN Target to GRI Management Approach Conversion"@en .


###  https://w3id.org/biodivrisK-onto#SantanderBrasil
:SantanderBrasil rdf:type owl:NamedIndividual ,
                          :FinancialInstitution ;
                 :appliesFramework :TNFD ;
                 :operatesInCountry :Brazil ;
                 :usesClassification :CNAE ;
                 rdfs:label "Santander Brasil"@en ;
                 <https://schema.org/url> <https://www.santander.com.br> .


###  https://w3id.org/biodivrisK-onto#SantanderPeru
:SantanderPeru rdf:type owl:NamedIndividual ,
                        :FinancialInstitution ;
               :appliesFramework :TNFD ;
               :hasPortfolioSector :AgriculturalProductsSector ,
                                   :MiningAndMetalsSector ;
               :operatesInCountry :Peru ;
               rdfs:label "Santander Peru"@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Banco Santander Perú S.A."@en ;
               <https://schema.org/url> <https://www.santander.com.pe> .


###  https://w3id.org/biodivrisK-onto#SantanderPeruESCCPolicy
:SantanderPeruESCCPolicy rdf:type owl:NamedIndividual ,
                                  :InternalPolicy ;
                         :coversRequirement :GRIProtectedAreaKBA ;
                         rdfs:comment "Santander Peru's Environmental, Social, Climate and Compliance (ESCC) risk management policy. Covers IUCN protected areas and Ramsar sites but does not extend to all TNFD sensitive location criteria (rapid ecosystem decline, high water stress)."@en ;
                         rdfs:label "Santander Peru ESCC Risk Policy"@en .


###  https://w3id.org/biodivrisK-onto#SantanderPeruL4Assessment
:SantanderPeruL4Assessment rdf:type owl:NamedIndividual ,
                                    :LEAPAssessment ;
                           :informsTargetSetting :SBTNAR3TTargetInstance ;
                           :requiresDataFrom :ENCOREData ,
                                             :GlobalForestWatchData ,
                                             :WRIAqueductData ;
                           rdfs:comment "Santander Peru's LEAP assessment conducted during Global Canopy's TNFD familiarisation programme in 2024, covering scoping and the full Locate phase (L1-L4). Source: Global Canopy & Santander Peru (2025)."@en ;
                           rdfs:label "Santander Peru LEAP L4 Assessment"@en ;
                           <http://www.w3.org/ns/prov#wasAssociatedWith> :SantanderPeru .


###  https://w3id.org/biodivrisK-onto#TNFD
:TNFD rdf:type owl:NamedIndividual ,
               :DisclosureFramework ;
      rdfs:label "TNFD"@en ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Taskforce on Nature-related Financial Disclosures"@en ;
      <https://schema.org/url> <https://tnfd.global> .


###  https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality
:TNFDEnterpriseMateriality rdf:type owl:NamedIndividual ;
                           :coveredByFramework :ESRS_E4 ;
                           :definedBy :TNFD ;
                           :incommensurableWith :ESRSDoubleMateriality .


