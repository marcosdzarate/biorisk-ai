<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:bro="https://w3id.org/biodivrisK-onto#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:schema="https://schema.org/"
  xmlns:vann="http://purl.org/vocab/vann/"
  xmlns:prov="http://www.w3.org/ns/prov#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#AtlanticForest">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Biome"/>
    <rdfs:label xml:lang="en">Atlantic Forest Biome</rdfs:label>
    <skos:altLabel xml:lang="pt">Mata Atlântica</skos:altLabel>
    <rdfs:comment xml:lang="en">Critical biodiversity hotspot — less than 29% of original cover remains. Among the most threatened biomes in the world. Relevant to CEBDS Brazil case.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#coveredByFramework">
    <rdfs:label xml:lang="en">covered by framework</rdfs:label>
    <rdfs:comment xml:lang="en">Relates a framework concept to the frameworks that include or address it.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#Cerrado">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Biome"/>
    <rdfs:label xml:lang="en">Cerrado Biome</rdfs:label>
    <rdfs:comment xml:lang="en">Brazilian tropical savanna — global biodiversity hotspot under severe agricultural pressure. 67.7% increase in deforestation in 2023. Under-sampled in GBIF for its specific endemic species.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#mappableTo">
    <rdfs:label xml:lang="en">mappable to</rdfs:label>
    <rdfs:comment xml:lang="en">A lossy correspondence between two industrial classification standards requiring manual effort and producing semantic ambiguity.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
  </owl:ObjectProperty>
  <owl:Ontology rdf:about="https://w3id.org/biodivrisK-onto">
    <owl:versionIRI rdf:resource="https://w3id.org/biodivrisK-onto/0.2.0"/>
    <owl:versionIRI rdf:resource="https://w3id.org/biodivrisK-onto/0.1.0"/>
    <owl:imports rdf:resource="https://w3id.org/biodivrisK-onto/0.1.0"/>
    <dcterms:title xml:lang="en">BiodivRisk-Onto v0.2.0: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks</dcterms:title>
    <dcterms:title xml:lang="en">BiodivRisk-Onto: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks</dcterms:title>
    <dcterms:description xml:lang="en">Extension of v0.1.0 with organizational, geographic, and evaluation modules, populated with real-world instances from the Santander Peru and CEBDS Brazil case studies.</dcterms:description>
    <dcterms:description xml:lang="en">BiodivRisk-Onto provides a formal OWL 2 DL representation of the semantic relations between four international biodiversity risk disclosure frameworks — TNFD, CSRD/ESRS E4, SBTN and GRI 101 — with particular attention to the data gaps arising from GBIF/OBIS sampling bias in Latin America and the Caribbean (LAC).</dcterms:description>
    <dcterms:creator>
      <schema:Person rdf:nodeID="n5e26570e22bf49059752cef39ec9f318b1">
        <schema:name>Marcos Daniel Zárate</schema:name>
        <schema:affiliation>CESIMAR-CONICET, Puerto Madryn, Argentina</schema:affiliation>
        <schema:url rdf:resource="https://orcid.org/0000-0001-8851-8602"/>
      </schema:Person>
    </dcterms:creator>
    <dcterms:creator>
      <schema:Person rdf:nodeID="n5e26570e22bf49059752cef39ec9f318b2">
        <schema:name>Gustavo Nuñez</schema:name>
        <schema:affiliation>CESIMAR-CONICET, Puerto Madryn, Argentina</schema:affiliation>
      </schema:Person>
    </dcterms:creator>
    <dcterms:creator>
      <schema:Person rdf:nodeID="na017e31c3a1f4e8e861b652ee6b55bd7b1">
        <schema:name>Marcos Daniel Zárate</schema:name>
        <schema:affiliation>CESIMAR-CONICET, Puerto Madryn, Argentina</schema:affiliation>
        <schema:url rdf:resource="https://orcid.org/0000-0001-8851-8602"/>
      </schema:Person>
    </dcterms:creator>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-21</dcterms:created>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-13</dcterms:created>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <vann:preferredNamespacePrefix>bro</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>https://w3id.org/biodivrisK-onto#</vann:preferredNamespaceUri>
    <owl:versionInfo>0.2.0</owl:versionInfo>
    <owl:versionInfo>0.1.0</owl:versionInfo>
    <rdfs:seeAlso rdf:resource="https://github.com/marcosdzarate/biorisk-ai/tree/main/ontology"/>
    <rdfs:seeAlso rdf:resource="https://github.com/marcosdzarate/biorisk-ai"/>
    <rdfs:comment xml:lang="en">Prototype v0.1.0. Developed as part of the paper submitted to AMW 2026.</rdfs:comment>
  </owl:Ontology>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CIIUtoGICSMapping">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#SemanticAmbiguity"/>
    <rdfs:label xml:lang="en">CIIU to GICS/SASB Mapping (Santander Peru)</rdfs:label>
    <rdfs:comment xml:lang="en">Manual sector correspondence developed by Santander Peru to align its CIIU-classified portfolio with GICS and SASB/SICS sectors required for ENCORE-based materiality screening.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#LACGeographicBias">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#GeographicSamplingBias"/>
    <rdfs:label xml:lang="en">LAC Geographic Sampling Bias</rdfs:label>
    <rdfs:comment xml:lang="en">Systematic under-sampling of GBIF and OBIS records for key LAC biomes including the tropical Andes, Amazonia, the Cerrado and Caribbean marine ecosystems. Leads to false negatives in TNFD priority-location and ESRS E4 sensitive-area proximity screening.</rdfs:comment>
    <bro:affectsFramework>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#TNFD">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
        <rdfs:label xml:lang="en">TNFD</rdfs:label>
        <skos:prefLabel xml:lang="en">Taskforce on Nature-related Financial Disclosures</skos:prefLabel>
        <schema:url rdf:resource="https://tnfd.global"/>
      </owl:NamedIndividual>
    </bro:affectsFramework>
    <bro:affectsFramework>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#ESRS_E4">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
        <rdfs:label xml:lang="en">CSRD/ESRS E4</rdfs:label>
        <skos:prefLabel xml:lang="en">European Sustainability Reporting Standard on Biodiversity and Ecosystems</skos:prefLabel>
        <schema:url rdf:resource="https://www.efrag.org"/>
      </owl:NamedIndividual>
    </bro:affectsFramework>
    <bro:affectsFramework>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SBTN">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
        <rdfs:label xml:lang="en">SBTN</rdfs:label>
        <skos:prefLabel xml:lang="en">Science Based Targets Network for Nature</skos:prefLabel>
        <schema:url rdf:resource="https://sciencebasedtargetsnetwork.org"/>
      </owl:NamedIndividual>
    </bro:affectsFramework>
    <bro:affectsFramework>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#GRI101">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
        <rdfs:label xml:lang="en">GRI 101</rdfs:label>
        <skos:prefLabel xml:lang="en">GRI 101: Biodiversity Standard 2024</skos:prefLabel>
        <schema:url rdf:resource="https://www.globalreporting.org"/>
      </owl:NamedIndividual>
    </bro:affectsFramework>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#usesClassification">
    <rdfs:label xml:lang="en">uses classification</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#Organization"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#AndeanWaterStressRisk">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#WaterStressRisk"/>
    <rdfs:label xml:lang="en">Andean Water Stress Risk</rdfs:label>
    <rdfs:comment xml:lang="en">Physical risk from insufficient freshwater availability in Andean mining and agricultural operations in Peru. Identified as a material dependency in Santander Peru LEAP L2: groundwater use and protection against flooding were the most material ecosystem service dependencies. High water stress zones identified via WRI Aqueduct in LEAP L4.</rdfs:comment>
    <bro:affectsRiskAssessment rdf:resource="https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality"/>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#TNFDLandUseChangeMetric">
    <bro:coveredByFramework rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#Metric"/>
    <rdfs:label xml:lang="en">TNFD Land/Freshwater/Ocean-use Change Metric</rdfs:label>
    <rdfs:comment xml:lang="en">TNFD core cross-sector metric measuring the extent (ha) of land, freshwater or ocean-use change.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
    <bro:unit xml:lang="en">hectares (ha)</bro:unit>
    <owl:equivalentClass rdf:resource="https://w3id.org/biodivrisK-onto#ESRSLandUseDatapoint"/>
    <skos:note xml:lang="en">Equivalence holds because both classes measure the same physical quantity (land-use change in hectares) using the same unit. One of the rare genuine equivalences between the four frameworks.</skos:note>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#operatesInCountry">
    <rdfs:label xml:lang="en">operates in country</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#Organization"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#Country"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasPortfolioSector">
    <rdfs:label xml:lang="en">has portfolio sector</rdfs:label>
    <rdfs:comment xml:lang="en">Relates a financial institution to an economic sector represented in its credit or investment portfolio.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#FinancialInstitution"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasInformationLoss">
    <rdfs:label xml:lang="en">has information loss</rdfs:label>
    <rdfs:comment xml:lang="en">Documents what information is lost when converting between two incommensurable framework concepts.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#InformationLoss"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#AndeanDataGap">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#GeographicSamplingBias"/>
    <rdfs:label xml:lang="en">Andean GBIF Data Gap</rdfs:label>
    <rdfs:comment xml:lang="en">Documented under-sampling of species occurrence records in GBIF for the tropical Andes biome, including Peru. Bias towards roads, cities and protected area boundaries. Leads to false negatives in TNFD priority-location screening. Empirically documented in Santander Peru LEAP L3-L4 assessment.</rdfs:comment>
    <bro:affectsFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
    <bro:affectsFramework rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
  </owl:NamedIndividual>
  <owl:AnnotationProperty rdf:about="https://w3id.org/biodivrisK-onto#unit">
    <rdfs:label xml:lang="en">unit</rdfs:label>
    <rdfs:comment xml:lang="en">Unit of measurement associated with a metric.</rdfs:comment>
  </owl:AnnotationProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasDataSufficiency">
    <rdfs:label xml:lang="en">has data sufficiency</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#DataSufficiencyAssessment"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#Biome"/>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#TaxonomicSamplingBias">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#DataGap"/>
    <rdfs:label xml:lang="en">Taxonomic Sampling Bias</rdfs:label>
    <rdfs:comment xml:lang="en">Systematic over-representation of certain taxonomic groups (e.g. birds, vascular plants) in open biodiversity databases.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#ESRSBiodiversitySensitiveArea">
    <owl:equivalentClass rdf:resource="https://w3id.org/biodivrisK-onto#GRIOperationsAdjacentProtectedAreas"/>
    <skos:note xml:lang="en">Partial equivalence with difference in reference: both concepts cover protected areas and KBAs, but ESRS E4 explicitly references Natura 2000 sites and IUCN Category I-IV protected areas, while GRI 101 uses a broader definition based on IUCN and Ramsar without the Natura 2000 specificity. The equivalence holds for the KBA criterion; the normative reference to EU-specific designations introduces a scope difference.</skos:note>
    <skos:note xml:lang="en">ESRS E4 biodiversity-sensitive areas are a strict subset of TNFD priority locations. TNFD additionally covers rapid ecosystem decline and high water stress sites absent from the ESRS definition. Treating as equivalent produces false negatives in LAC screening.</skos:note>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#TNFDPriorityLocation"/>
    <rdfs:label xml:lang="en">ESRS E4 Biodiversity-sensitive Area</rdfs:label>
    <rdfs:comment xml:lang="en">Areas designated for biodiversity protection under ESRS E4, including Natura 2000 sites, UNESCO World Heritage, KBAs, and IUCN Category I–IV protected areas.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#affectsRiskAssessment">
    <rdfs:label xml:lang="en">affects risk assessment</rdfs:label>
    <rdfs:comment xml:lang="en">Relates a materiality boundary gap to the type of physical risk whose assessment is affected.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityBoundary"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#PhysicalRisk"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#affectsFramework">
    <rdfs:label xml:lang="en">affects framework</rdfs:label>
    <rdfs:comment xml:lang="en">Relates a data gap to the framework(s) whose assessments are affected.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#DataGap"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#Portfolio">
    <rdfs:label xml:lang="en">Portfolio</rdfs:label>
    <rdfs:comment xml:lang="en">A credit or investment portfolio of a financial institution, composed of assets across multiple economic sectors and geographic locations.</rdfs:comment>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasMaterialityApproach">
    <rdfs:label xml:lang="en">has materiality approach</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityApproach"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#TNFDStrategyD">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureRequirement"/>
    <rdfs:label xml:lang="en">TNFD Strategy D</rdfs:label>
    <rdfs:comment xml:lang="en">TNFD recommended disclosure Strategy D: disclose the locations of assets and/or activities in direct operations and, where possible, upstream and downstream value chains that meet the criteria for priority locations.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CerradoDataGap">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#GeographicSamplingBias"/>
    <rdfs:label xml:lang="en">Cerrado GBIF Data Gap</rdfs:label>
    <rdfs:comment xml:lang="en">Documented under-sampling of species occurrence records in GBIF for the Cerrado biome, particularly invertebrates and endemic species. Documented in the CEBDS Brazil LEAP pilot as a challenge for L4 sensitive site identification.</rdfs:comment>
    <bro:affectsFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
    <bro:affectsFramework rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#ENCOREScale">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#QuantitativeMaterialityScale"/>
    <rdfs:label xml:lang="en">ENCORE Scale 3-9</rdfs:label>
    <rdfs:comment xml:lang="en">ENCORE numerical scale where 3=very low, 4.5=low, 6=medium, 7.5=high, 9=very high dependency/impact. Used in CEBDS Brazil pilot to produce heatmap weighted by loan volume and client count.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#requiresDataFrom">
    <rdfs:label xml:lang="en">requires data from</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#LEAPAssessment"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#BiodiversityDataSource"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasDataGapIn">
    <rdfs:label xml:lang="en">has data gap in</rdfs:label>
    <rdfs:comment xml:lang="en">Relates a disclosure framework to a biome where its data requirements cannot be met due to GBIF/OBIS sampling bias.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#Biome"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasEvaluationResult">
    <rdfs:label xml:lang="en">has evaluation result</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#LEAPAssessment"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityResult"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#definedBy">
    <rdfs:label xml:lang="en">defined by</rdfs:label>
    <rdfs:comment xml:lang="en">Relates a framework concept class to the framework that defines it.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#prioritisesSector">
    <rdfs:label xml:lang="en">prioritises sector</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityResult"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#GRIImpactMateriality">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityBoundary"/>
    <rdfs:label xml:lang="en">GRI Impact Materiality</rdfs:label>
    <rdfs:comment xml:lang="en">GRI impact-only materiality: issues are material based on significance of actual or potential impacts on people and environment, regardless of financial consequences.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#GRI101"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#operatesInBiome">
    <rdfs:label xml:lang="en">operates in biome</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#Organization"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#Biome"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SASB_SICS">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
    <rdfs:label xml:lang="en">SASB SICS</rdfs:label>
    <skos:prefLabel xml:lang="en">SASB Sustainable Industry Classification System</skos:prefLabel>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#PriorityLocation">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:label xml:lang="en">Priority Location</rdfs:label>
    <rdfs:comment xml:lang="en">A geographic location identified as high-priority for biodiversity assessment under TNFD LEAP L4, based on five sensitive location criteria: (1) important for biodiversity; (2) high ecosystem integrity; (3) rapid ecosystem decline; (4) high physical water risk; (5) important for ecosystem services provision.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SantanderPeruESCCPolicy">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#InternalPolicy"/>
    <rdfs:label xml:lang="en">Santander Peru ESCC Risk Policy</rdfs:label>
    <rdfs:comment xml:lang="en">Santander Peru's Environmental, Social, Climate and Compliance (ESCC) risk management policy. Covers IUCN protected areas and Ramsar sites but does not extend to all TNFD sensitive location criteria (rapid ecosystem decline, high water stress).</rdfs:comment>
    <bro:coversRequirement>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#GRIProtectedAreaKBA">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureRequirement"/>
        <rdfs:label xml:lang="en">GRI 101 Operations in/adjacent to Protected Areas and KBAs</rdfs:label>
        <rdfs:comment xml:lang="en">GRI 101-6: disclosure of operations located in, adjacent to, or containing protected areas or Key Biodiversity Areas.</rdfs:comment>
        <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#GRI101"/>
      </owl:NamedIndividual>
    </bro:coversRequirement>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasSectorClassification">
    <rdfs:label xml:lang="en">has sector classification</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#complements">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="en">complements</rdfs:label>
    <rdfs:comment xml:lang="en">Two framework concept classes that address distinct, jointly-required facets of one assessment. Licenses composition of evidence, not substitution. Symmetric.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>
  <owl:AnnotationProperty rdf:about="https://w3id.org/biodivrisK-onto#hasBridgingCondition">
    <rdfs:label xml:lang="en">has bridging condition</rdfs:label>
    <rdfs:comment xml:lang="en">Documents the explicit assumption under which a lossy approximation between two incommensurable concepts is admissible. Required on every bro:incommensurableWith assertion.</rdfs:comment>
  </owl:AnnotationProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#Amazonia">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Biome"/>
    <rdfs:label xml:lang="en">Amazonia Biome</rdfs:label>
    <rdfs:comment xml:lang="en">Largest tropical rainforest biome globally. Under-sampled in GBIF particularly for invertebrates and cryptic taxa. Relevant to both Santander Peru and CEBDS Brazil cases.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#appliesFramework">
    <rdfs:label xml:lang="en">applies framework</rdfs:label>
    <rdfs:comment xml:lang="en">Relates an organization to a disclosure framework it applies or is subject to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#Organization"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#incommensurableWith">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:label xml:lang="en">incommensurable with</rdfs:label>
    <rdfs:comment xml:lang="en">Two framework concept classes for which no truth-preserving mapping exists due to different measurement units, materiality boundaries or epistemic commitments. Every assertion MUST carry bro:hasBridgingCondition. Symmetric.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#OBISData">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#BiodiversityDataSource"/>
    <rdfs:label xml:lang="en">OBIS Marine Data</rdfs:label>
    <rdfs:comment xml:lang="en">Ocean Biodiversity Information System — primary open source for marine species occurrence records. Under-representation of Caribbean marine ecosystems.</rdfs:comment>
    <schema:url rdf:resource="https://obis.org"/>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#coversRequirement">
    <rdfs:label xml:lang="en">covers requirement</rdfs:label>
    <rdfs:comment xml:lang="en">Relates an internal policy to the disclosure requirements of external frameworks that it partially or fully covers.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#InternalPolicy"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureRequirement"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CNAEtoGICSMapping">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#SemanticAmbiguity"/>
    <rdfs:label xml:lang="en">CNAE to GICS Mapping (CEBDS Brazil)</rdfs:label>
    <rdfs:comment xml:lang="en">Manual sector correspondence developed during the CEBDS Brazil LEAP pilot to align portfolio reporting under CNAE with ENCORE/TNFD materiality assessment requiring GICS classification.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SBTNtargetToGRIConversion">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#InformationLoss"/>
    <rdfs:label xml:lang="en">SBTN Target to GRI Management Approach Conversion</rdfs:label>
    <rdfs:comment xml:lang="en">Information loss documented when converting an SBTN science-based target (measurable, time-bound, science-grounded) to a GRI 101 management approach disclosure (qualitative, policy-level). Lost information includes: (1) quantitative target value, (2) scientific baseline, (3) time horizon commitment, (4) verifiability. Bridging condition: the GRI management approach must explicitly commit to SBTN-compatible targets with verified science-based baselines.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#assessedUnder">
    <rdfs:label xml:lang="en">assessed under</rdfs:label>
    <rdfs:comment xml:lang="en">Relates a sector or portfolio to the disclosure framework under which it was assessed for materiality.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#DisclosureFramework"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasAmbiguity">
    <rdfs:label xml:lang="en">has ambiguity</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#SemanticAmbiguity"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#hasScale">
    <rdfs:label xml:lang="en">has scale</rdfs:label>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityApproach"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#QuantitativeMaterialityScale"/>
  </owl:ObjectProperty>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#TropicalAndes">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Biome"/>
    <rdfs:label xml:lang="en">Tropical Andes Biome</rdfs:label>
    <rdfs:comment xml:lang="en">Biodiversity hotspot in the Andes mountains of Peru, Colombia, Ecuador and Bolivia. Under-sampled in GBIF: occurrence records biased towards roads and urban areas, with insufficient coverage of high-altitude species.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#GRIManagementApproach">
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#SBTNMeanSpeciesAbundance"/>
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:label xml:lang="en">GRI 101 Management Approach</rdfs:label>
    <rdfs:comment xml:lang="en">GRI 101 qualitative disclosure describing how an organisation manages its biodiversity impacts, policies, commitments and actions. No quantitative target required.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#GRI101"/>
    <bro:complements rdf:resource="https://w3id.org/biodivrisK-onto#TNFDImpactDependency"/>
    <skos:note xml:lang="en">GRI 101 management approach disclosures compose with TNFD nature-related risk narratives. Impact reporting under GRI informs but does not replace risk framing under TNFD.</skos:note>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#ESRSDoubleMateriality">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityBoundary"/>
    <rdfs:label xml:lang="en">ESRS E4 Double Materiality</rdfs:label>
    <rdfs:comment xml:lang="en">ESRS E4 double materiality: an issue is material if it has significant impacts on biodiversity (impact materiality) OR poses financial risks/opportunities (financial materiality).</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality"/>
    <bro:hasBridgingCondition xml:lang="en">A lossy approximation is admissible if the analyst explicitly assumes that impact-material issues under ESRS E4 are also financially material under TNFD, and documents this assumption with supporting evidence. Does not hold by default.</bro:hasBridgingCondition>
    <skos:note xml:lang="en">ESRS E4 double materiality requires assessment of both impact and financial dimensions. TNFD applies single enterprise-value materiality. The two boundaries define different populations of disclosable items; thresholds are not interchangeable.</skos:note>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#UtilitiesSector">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:label xml:lang="en">Utilities Sector</rdfs:label>
    <bro:hasSectorClassification>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#GICS">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
        <rdfs:label xml:lang="en">GICS</rdfs:label>
        <skos:prefLabel xml:lang="en">Global Industry Classification Standard</skos:prefLabel>
        <rdfs:comment xml:lang="en">International sector classification used by ENCORE and TNFD for materiality assessment.</rdfs:comment>
        <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#CNAE"/>
        <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#CIIU"/>
      </owl:NamedIndividual>
    </bro:hasSectorClassification>
    <bro:assessedUnder rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#GBIFData">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#BiodiversityDataSource"/>
    <rdfs:label xml:lang="en">GBIF Occurrence Data</rdfs:label>
    <rdfs:comment xml:lang="en">Global Biodiversity Information Facility — primary open source for terrestrial and freshwater species occurrence records. Exhibits geographic sampling bias in LAC: under-representation of Andes, Amazonia and Cerrado.</rdfs:comment>
    <schema:url rdf:resource="https://www.gbif.org"/>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#Biome">
    <rdfs:label xml:lang="en">Biome</rdfs:label>
    <rdfs:comment xml:lang="en">A major ecological zone characterized by distinctive climate, vegetation and biodiversity. Reuses ENVO biome concept (ENVO:00000428). In LAC, biomes are megadiverse and systematically under-sampled in GBIF/OBIS.</rdfs:comment>
    <owl:equivalentClass rdf:resource="http://purl.obolibrary.org/obo/ENVO_00000428"/>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#ENCOREMateriality">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#QuantitativeMaterialityScale"/>
    <rdfs:label xml:lang="en">ENCORE Quantitative Materiality Scale</rdfs:label>
    <rdfs:comment xml:lang="en">ENCORE scores impacts and dependencies on a numerical scale: very low=3, low=4.5, medium=6, high=7.5, very high=9. Used by TNFD for sector-level screening.</rdfs:comment>
    <bro:incommensurableWith>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#GRI101ImpactMateriality">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#QualitativeMaterialityScale"/>
        <rdfs:label xml:lang="en">GRI 101 Impact Materiality</rdfs:label>
        <rdfs:comment xml:lang="en">GRI 101 applies impact materiality: issues are material based on the significance of actual or potential impacts on people and the environment, assessed through stakeholder engagement and qualitative severity criteria.</rdfs:comment>
        <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#ENCOREMateriality"/>
      </owl:NamedIndividual>
    </bro:incommensurableWith>
    <bro:hasBridgingCondition xml:lang="en">A lossy approximation is admissible if ENCORE sector scores are supplemented with qualitative stakeholder evidence meeting GRI 101 impact severity criteria. The numerical scale (3-9) cannot be directly compared with GRI qualitative thresholds without explicit bridging assumptions documented per sector.</bro:hasBridgingCondition>
    <skos:note xml:lang="en">ENCORE applies a quantitative composite scale (3-9) aggregating dependencies and impacts by production process. GRI 101 applies qualitative impact materiality requiring stakeholder-informed severity assessment. The two approaches operate at different epistemic levels and use incompatible measurement units.</skos:note>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#ESRSLandUseDatapoint">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#Metric"/>
    <rdfs:label xml:lang="en">ESRS E4 Land-use Change Datapoint</rdfs:label>
    <rdfs:comment xml:lang="en">ESRS E4 datapoint requiring disclosure of land-use change in hectares attributable to the undertaking's own operations and value chain.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
    <bro:unit xml:lang="en">hectares (ha)</bro:unit>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CEBDSBrazilLocateAssessment">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#LEAPAssessment"/>
    <rdfs:label xml:lang="en">CEBDS Brazil TNFD Locate Phase Pilot</rdfs:label>
    <rdfs:comment xml:lang="en">Collective piloting of the TNFD LEAP Locate phase by 5 Brazilian financial institutions coordinated by CEBDS and technically led by EY, September 2023–September 2024. Source: CEBDS/EY (2024).</rdfs:comment>
    <bro:requiresDataFrom>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#ENCOREData">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#BiodiversityDataSource"/>
        <rdfs:label xml:lang="en">ENCORE Tool</rdfs:label>
        <rdfs:comment xml:lang="en">Exploring Natural Capital Opportunities, Risks and Exposure — sector-level tool for screening nature-related impacts and dependencies. Uses a quantitative scale (3-9). Used in L2 by both Santander Peru and CEBDS Brazil.</rdfs:comment>
        <schema:url rdf:resource="https://encorenature.org"/>
      </owl:NamedIndividual>
    </bro:requiresDataFrom>
    <bro:requiresDataFrom>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#WRIAqueductData">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#BiodiversityDataSource"/>
        <rdfs:label xml:lang="en">WRI Aqueduct</rdfs:label>
        <rdfs:comment xml:lang="en">World Resources Institute water risk atlas — used in LEAP L4 to identify high physical water stress zones. Used by both case study institutions.</rdfs:comment>
        <schema:url rdf:resource="https://www.wri.org/aqueduct"/>
      </owl:NamedIndividual>
    </bro:requiresDataFrom>
    <bro:requiresDataFrom rdf:resource="https://w3id.org/biodivrisK-onto#GBIFData"/>
    <bro:hasEvaluationResult>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CEBDSHeatmapResult">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityResult"/>
        <rdfs:label xml:lang="en">CEBDS Brazil Sector Heatmap Result</rdfs:label>
        <rdfs:comment xml:lang="en">Sectoral materiality ranking from the CEBDS Brazil LEAP pilot using ENCORE scores combined with loan volume and number of clients data. Priority order: 1st Consumer Staples, 2nd Consumer Discretionary, 3rd Utilities, 4th Industrials.</rdfs:comment>
        <bro:prioritisesSector rdf:resource="https://w3id.org/biodivrisK-onto#ConsumerStaplesSector"/>
        <bro:prioritisesSector rdf:resource="https://w3id.org/biodivrisK-onto#ConsumerDiscretionarySector"/>
        <bro:prioritisesSector rdf:resource="https://w3id.org/biodivrisK-onto#UtilitiesSector"/>
        <bro:prioritisesSector rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialsSector"/>
      </owl:NamedIndividual>
    </bro:hasEvaluationResult>
    <prov:wasAssociatedWith>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#BNDES">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#FinancialInstitution"/>
        <rdfs:label xml:lang="en">BNDES</rdfs:label>
        <skos:prefLabel xml:lang="en">Banco Nacional de Desenvolvimento Econômico e Social</skos:prefLabel>
        <schema:url rdf:resource="https://www.bndes.gov.br"/>
        <bro:appliesFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
        <bro:operatesInCountry rdf:resource="https://w3id.org/biodivrisK-onto#Brazil"/>
        <bro:usesClassification rdf:resource="https://w3id.org/biodivrisK-onto#CNAE"/>
      </owl:NamedIndividual>
    </prov:wasAssociatedWith>
    <prov:wasAssociatedWith>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#Bradesco">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#FinancialInstitution"/>
        <rdfs:label xml:lang="en">Banco Bradesco</rdfs:label>
        <schema:url rdf:resource="https://www.bradesco.com.br"/>
        <bro:appliesFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
        <bro:operatesInCountry rdf:resource="https://w3id.org/biodivrisK-onto#Brazil"/>
        <bro:usesClassification rdf:resource="https://w3id.org/biodivrisK-onto#CNAE"/>
      </owl:NamedIndividual>
    </prov:wasAssociatedWith>
    <prov:wasAssociatedWith>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#Caixa">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#FinancialInstitution"/>
        <rdfs:label xml:lang="en">Caixa Econômica Federal</rdfs:label>
        <schema:url rdf:resource="https://www.caixa.gov.br"/>
        <bro:appliesFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
        <bro:operatesInCountry rdf:resource="https://w3id.org/biodivrisK-onto#Brazil"/>
        <bro:usesClassification rdf:resource="https://w3id.org/biodivrisK-onto#CNAE"/>
      </owl:NamedIndividual>
    </prov:wasAssociatedWith>
    <prov:wasAssociatedWith>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#ItauUnibanco">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#FinancialInstitution"/>
        <rdfs:label xml:lang="en">Itaú Unibanco</rdfs:label>
        <schema:url rdf:resource="https://www.itau.com.br"/>
        <bro:appliesFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
        <bro:operatesInCountry rdf:resource="https://w3id.org/biodivrisK-onto#Brazil"/>
        <bro:usesClassification rdf:resource="https://w3id.org/biodivrisK-onto#CNAE"/>
      </owl:NamedIndividual>
    </prov:wasAssociatedWith>
    <prov:wasAssociatedWith>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SantanderBrasil">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#FinancialInstitution"/>
        <rdfs:label xml:lang="en">Santander Brasil</rdfs:label>
        <schema:url rdf:resource="https://www.santander.com.br"/>
        <bro:appliesFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
        <bro:operatesInCountry rdf:resource="https://w3id.org/biodivrisK-onto#Brazil"/>
        <bro:usesClassification rdf:resource="https://w3id.org/biodivrisK-onto#CNAE"/>
      </owl:NamedIndividual>
    </prov:wasAssociatedWith>
    <bro:informsTargetSetting>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SBTNAR3TTargetInstance">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"/>
        <rdfs:label xml:lang="en">SBTN AR3T Science-based Target</rdfs:label>
        <rdfs:comment xml:lang="en">A science-based target following the SBTN AR3T hierarchy (Avoid, Reduce, Restore, Transform), as applicable to financial institutions assessing their portfolio exposure to nature loss. Requires LEAP assessment outputs as input for geographic and sectoral target-setting.</rdfs:comment>
        <bro:requiresInputFrom rdf:resource="https://w3id.org/biodivrisK-onto#SantanderPeruL4Assessment"/>
        <bro:requiresInputFrom rdf:resource="https://w3id.org/biodivrisK-onto#CEBDSBrazilLocateAssessment"/>
      </owl:NamedIndividual>
    </bro:informsTargetSetting>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#QuantitativeMaterialityScale">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityApproach"/>
    <rdfs:label xml:lang="en">Quantitative Materiality Scale</rdfs:label>
    <rdfs:comment xml:lang="en">A numerical scale used to score materiality of nature-related impacts and dependencies (e.g., ENCORE scale 3-9: very low=3, low=4.5, medium=6, high=7.5, very high=9).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#GeographicSamplingBias">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#DataGap"/>
    <rdfs:label xml:lang="en">Geographic Sampling Bias</rdfs:label>
    <rdfs:comment xml:lang="en">Systematic under-representation of species occurrences in GBIF/OBIS records for specific geographic regions.</rdfs:comment>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CNAE">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
    <rdfs:label xml:lang="en">CNAE</rdfs:label>
    <skos:prefLabel xml:lang="en">Classificação Nacional de Atividades Econômicas</skos:prefLabel>
    <rdfs:comment xml:lang="en">Brazilian national industrial classification used by financial institutions for portfolio reporting. Requires manual mapping to GICS for TNFD/ENCORE assessments.</rdfs:comment>
    <bro:mappableTo rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:hasAmbiguity>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CNAEtoGICSAmbiguity">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#SemanticAmbiguity"/>
        <rdfs:label xml:lang="en">CNAE to GICS Semantic Ambiguity</rdfs:label>
        <rdfs:comment xml:lang="en">Documented semantic ambiguity in the CNAE-to-GICS mapping required for TNFD/ENCORE assessments. Brazilian CNAE categories do not maintain a bijective correspondence with GICS sectors — multiple CNAE codes may map to one GICS sector or vice versa. Required significant manual effort in the CEBDS Brazil pilot.</rdfs:comment>
      </owl:NamedIndividual>
    </bro:hasAmbiguity>
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:hasBridgingCondition xml:lang="en">A lossy correspondence is admissible when each CNAE code is manually mapped to the most representative GICS sector, with explicit documentation of multi-to-one and one-to-many correspondences. This mapping was performed by EY during the CEBDS Brazil LEAP pilot and required significant expert effort. The result is not automatically reversible.</bro:hasBridgingCondition>
    <skos:note xml:lang="en">CNAE (Brazilian national classification) and GICS (international standard used by ENCORE/TNFD) do not maintain a bijective correspondence. Multiple CNAE codes may map to one GICS sector and vice versa, generating semantic ambiguity in sector-level materiality assessments.</skos:note>
  </owl:NamedIndividual>
  <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#requiresInputFrom">
    <rdfs:label xml:lang="en">requires input from</rdfs:label>
    <rdfs:comment xml:lang="en">A directed property: SBTN AR3T target setting requires location and materiality data produced by a TNFD LEAP assessment.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"/>
    <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#LEAPAssessment"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/biodivrisK-onto#informsTargetSetting">
        <rdfs:label xml:lang="en">informs target setting</rdfs:label>
        <rdfs:comment xml:lang="en">A directed property: the output of a LEAP assessment informs the science-based target-setting process of SBTN AR3T.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/biodivrisK-onto#LEAPAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"/>
        <owl:inverseOf rdf:resource="https://w3id.org/biodivrisK-onto#requiresInputFrom"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#WaterStressRisk">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#PhysicalRisk"/>
    <rdfs:label xml:lang="en">Water Stress Risk</rdfs:label>
    <rdfs:comment xml:lang="en">Physical risk arising from insufficient availability or quality of freshwater resources, particularly relevant for mining and agricultural sectors in the Andes. Identified as material dependency in the Santander Peru LEAP assessment (L2).</rdfs:comment>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CIIU">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#IndustrialClassification"/>
    <rdfs:label xml:lang="en">CIIU</rdfs:label>
    <skos:prefLabel xml:lang="en">Clasificación Industrial Internacional Uniforme</skos:prefLabel>
    <rdfs:comment xml:lang="en">UN international industrial classification used in Peru. Requires manual mapping to GICS/SASB for TNFD assessments.</rdfs:comment>
    <bro:mappableTo rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:hasAmbiguity>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#CIIUtoGICSAmbiguity">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#SemanticAmbiguity"/>
        <rdfs:label xml:lang="en">CIIU to GICS Semantic Ambiguity</rdfs:label>
        <rdfs:comment xml:lang="en">Documented semantic ambiguity in the CIIU-to-GICS/SASB mapping required for TNFD assessments in Peru. Peruvian CIIU categories require manual alignment with GICS and SASB/SICS sector definitions.</rdfs:comment>
      </owl:NamedIndividual>
    </bro:hasAmbiguity>
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:hasBridgingCondition xml:lang="en">A lossy correspondence requires manual alignment of CIIU codes to GICS and SASB/SICS sectors, with documentation of ambiguous cases. Performed by Santander Peru during LEAP L1 scoping.</bro:hasBridgingCondition>
    <skos:note xml:lang="en">CIIU (UN international classification used in Peru) does not map automatically to GICS or SASB/SICS sectors required for ENCORE-based TNFD assessments.</skos:note>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality">
    <bro:coveredByFramework rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#ESRSDoubleMateriality"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityBoundary"/>
    <rdfs:label xml:lang="en">TNFD Enterprise-value Materiality</rdfs:label>
    <rdfs:comment xml:lang="en">TNFD single (enterprise-value) materiality: an issue is material if it poses financial risks or opportunities to the reporting organisation.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#PhysicalRisk">
    <rdfs:label xml:lang="en">Physical Risk</rdfs:label>
    <rdfs:comment xml:lang="en">A nature-related physical risk arising from the degradation of ecosystems or natural capital, including water stress, ecosystem collapse, loss of pollination, erosion or flooding. Corresponds to TNFD and ESRS physical risk category.</rdfs:comment>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#ConsumerDiscretionarySector">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:label xml:lang="en">Consumer Discretionary Sector</rdfs:label>
    <bro:hasSectorClassification rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:assessedUnder rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#SBTNAR3TTarget">
    <bro:coveredByFramework rdf:resource="https://w3id.org/biodivrisK-onto#SBTN"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:label xml:lang="en">SBTN Science-based Target (AR3T)</rdfs:label>
    <rdfs:comment xml:lang="en">Measurable, time-bound target following the SBTN AR3T hierarchy: Avoid, Reduce, Restore, Transform.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#SBTN"/>
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#GRIManagementApproach"/>
    <bro:hasBridgingCondition xml:lang="en">A lossy approximation is admissible only if the GRI management approach explicitly commits to SBTN-compatible measurable targets with defined timelines and science-based baselines, AND those commitments are independently verified.</bro:hasBridgingCondition>
    <skos:note xml:lang="en">An SBTN science-based target is measurable, time-bound and grounded in scientific baselines. A GRI 101 management approach describes intent without required quantification. Different epistemic status: verifiable outcome commitment vs description of policy intent.</skos:note>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#SBTNMeanSpeciesAbundance">
    <bro:coveredByFramework rdf:resource="https://w3id.org/biodivrisK-onto#SBTN"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#Metric"/>
    <rdfs:label xml:lang="en">SBTN Mean Species Abundance (MSA)</rdfs:label>
    <rdfs:comment xml:lang="en">State-of-nature metric measuring biodiversity intactness as the average abundance of originally present species relative to their abundance in undisturbed ecosystems (GLOBIO model).</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#SBTN"/>
    <bro:unit xml:lang="en">dimensionless ratio (0–1)</bro:unit>
    <bro:incommensurableWith rdf:resource="https://w3id.org/biodivrisK-onto#GRIManagementApproach"/>
    <bro:hasBridgingCondition xml:lang="en">No direct conversion exists. A lossy approximation requires deriving a proxy MSA from operational footprint data AND documenting that the GRI management approach implies no specific biodiversity-state outcome. Not recommended for regulatory compliance.</bro:hasBridgingCondition>
    <skos:note xml:lang="en">MSA is a composite quantitative index measuring biodiversity intactness as a ratio. GRI 101 management approach is a qualitative policy disclosure with no implied biodiversity-state outcome. Different epistemic levels: state measurement vs organisational intent.</skos:note>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#FrameworkConcept">
    <rdfs:label xml:lang="en">Framework Concept</rdfs:label>
    <rdfs:comment xml:lang="en">A concept, disclosure requirement, indicator or metric defined within a disclosure framework. Subclasses represent specific concepts; individuals of this class are not intended.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#DisclosureRequirement">
    <rdfs:label xml:lang="en">Disclosure Requirement</rdfs:label>
    <rdfs:comment xml:lang="en">A specific disclosure requirement within a framework, at the level of a recommended disclosure, datapoint or metric (e.g., TNFD Strategy D, ESRS E4-5, GRI 101-6).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#InternalPolicy">
    <rdfs:label xml:lang="en">Internal Policy</rdfs:label>
    <rdfs:comment xml:lang="en">An organization's internal policy for managing environmental, social, climate or nature-related risks (e.g., an ESCC policy). May partially cover requirements of external disclosure frameworks.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#GRIOperationsAdjacentProtectedAreas">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#TNFDPriorityLocation"/>
    <rdfs:label xml:lang="en">GRI 101 Operations in/adjacent to Protected Areas and KBAs</rdfs:label>
    <rdfs:comment xml:lang="en">GRI 101 disclosure of operations located in, adjacent to, or containing protected areas or Key Biodiversity Areas.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#GRI101"/>
    <skos:note xml:lang="en">GRI 101 protected-area and KBA sites are a subset of TNFD areas of importance for biodiversity. TNFD applies a broader definition additionally covering areas of high biodiversity intactness beyond formal protection status.</skos:note>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#TNFDPriorityLocation">
    <bro:coveredByFramework rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:label xml:lang="en">TNFD Priority Location</rdfs:label>
    <rdfs:comment xml:lang="en">Location of high importance for biodiversity under TNFD LEAP, including areas of high biodiversity intactness, protected areas, KBAs, areas of rapid ecosystem decline, and areas of high water stress.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SantanderPeruL4Assessment">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#LEAPAssessment"/>
    <rdfs:label xml:lang="en">Santander Peru LEAP L4 Assessment</rdfs:label>
    <rdfs:comment xml:lang="en">Santander Peru's LEAP assessment conducted during Global Canopy's TNFD familiarisation programme in 2024, covering scoping and the full Locate phase (L1-L4). Source: Global Canopy &amp; Santander Peru (2025).</rdfs:comment>
    <bro:requiresDataFrom>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#GlobalForestWatchData">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#BiodiversityDataSource"/>
        <rdfs:label xml:lang="en">Global Forest Watch</rdfs:label>
        <rdfs:comment xml:lang="en">Near real-time forest monitoring platform used by Santander Peru in LEAP L3/L4 to map protected areas and KBAs across Peru.</rdfs:comment>
        <schema:url rdf:resource="https://www.globalforestwatch.org"/>
      </owl:NamedIndividual>
    </bro:requiresDataFrom>
    <bro:requiresDataFrom rdf:resource="https://w3id.org/biodivrisK-onto#ENCOREData"/>
    <bro:requiresDataFrom rdf:resource="https://w3id.org/biodivrisK-onto#WRIAqueductData"/>
    <prov:wasAssociatedWith>
      <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#SantanderPeru">
        <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#FinancialInstitution"/>
        <rdfs:label xml:lang="en">Santander Peru</rdfs:label>
        <skos:prefLabel xml:lang="en">Banco Santander Perú S.A.</skos:prefLabel>
        <schema:url rdf:resource="https://www.santander.com.pe"/>
        <bro:appliesFramework rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
        <bro:operatesInCountry rdf:resource="https://w3id.org/biodivrisK-onto#Peru"/>
        <bro:hasPortfolioSector rdf:resource="https://w3id.org/biodivrisK-onto#MiningAndMetalsSector"/>
        <bro:hasPortfolioSector rdf:resource="https://w3id.org/biodivrisK-onto#AgriculturalProductsSector"/>
      </owl:NamedIndividual>
    </prov:wasAssociatedWith>
    <bro:informsTargetSetting rdf:resource="https://w3id.org/biodivrisK-onto#SBTNAR3TTargetInstance"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#ConsumerStaplesSector">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:label xml:lang="en">Consumer Staples Sector</rdfs:label>
    <skos:definition xml:lang="en">Companies involved in the production or sale of essential products, including food, beverages, tobacco, and hygiene products. Priority 1 in CEBDS Brazil heatmap.</skos:definition>
    <bro:hasSectorClassification rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:assessedUnder rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#Metric">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:label xml:lang="en">Metric</rdfs:label>
    <rdfs:comment xml:lang="en">A quantitative or semi-quantitative indicator expressed in specific units or using a defined measurement approach.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#MaterialityResult">
    <rdfs:label xml:lang="en">Materiality Result</rdfs:label>
    <rdfs:comment xml:lang="en">The output of a materiality assessment — a ranked or scored set of sectors, locations or impacts identified as material under a specific framework and approach.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#Sector">
    <rdfs:label xml:lang="en">Economic Sector</rdfs:label>
    <rdfs:comment xml:lang="en">An economic sector associated with potential impacts and dependencies on nature, classifiable under international standards such as GICS or SASB/SICS.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#TNFDImpactDependency">
    <bro:coveredByFramework rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:label xml:lang="en">TNFD Impacts and Dependencies on Nature</rdfs:label>
    <rdfs:comment xml:lang="en">Core TNFD concept requiring organisations to identify both their impacts on nature and their dependencies on ecosystem services.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
    <owl:equivalentClass rdf:resource="https://w3id.org/biodivrisK-onto#ESRSMaterialImpactDependency"/>
    <skos:note xml:lang="en">Equivalence holds on the impact side only. Both classes share the ENCORE-derived logic of identifying organisational impacts on and dependencies upon nature. The financial materiality dimension of ESRS E4 double materiality has no direct equivalent in TNFD.</skos:note>
    <skos:note xml:lang="en">TNFD LEAP provides the assessment and disclosure process; SBTN AR3T provides science-based target-setting. SBTN targets feed into the TNFD strategy phase. Neither substitutes the other.</skos:note>
    <bro:complements rdf:resource="https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"/>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#BiodiversityDataSource">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <rdfs:label xml:lang="en">Biodiversity Data Source</rdfs:label>
    <rdfs:comment xml:lang="en">An open or proprietary data source used to obtain species occurrence, ecosystem integrity or water risk data during a LEAP assessment (e.g., GBIF, OBIS, ENCORE, Global Forest Watch, WRI Aqueduct, IBAT).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#IndustrialClassification">
    <rdfs:label xml:lang="en">Industrial Classification Standard</rdfs:label>
    <rdfs:comment xml:lang="en">A standard system for classifying economic activities into sectors and subsectors (e.g., GICS, CNAE, CIIU, SASB/SICS). Different standards may not be mutually translatable without ambiguity.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#MaterialityApproach">
    <rdfs:label xml:lang="en">Materiality Approach</rdfs:label>
    <rdfs:comment xml:lang="en">A methodological approach for determining which nature-related impacts, risks and opportunities are material and must be disclosed. Different frameworks apply different approaches (financial, impact, or double materiality) that are not mutually equivalent.</rdfs:comment>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#Peru">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Country"/>
    <rdfs:label xml:lang="en">Peru</rdfs:label>
    <rdfs:comment xml:lang="en">Megadiverse country — one of 17 globally. Second largest copper producer worldwide. High Andean and Amazonian biodiversity with documented GBIF sampling gaps.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#QualitativeMaterialityScale">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#MaterialityApproach"/>
    <rdfs:label xml:lang="en">Qualitative Materiality Scale</rdfs:label>
    <rdfs:comment xml:lang="en">A narrative or categorical approach to assessing materiality of nature-related impacts, without a fixed numerical scale (e.g., GRI 101 impact materiality approach).</rdfs:comment>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#IndustrialsSector">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:label xml:lang="en">Industrials Sector</rdfs:label>
    <bro:hasSectorClassification rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:assessedUnder rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#Country">
    <rdfs:subClassOf rdf:resource="https://schema.org/Country"/>
    <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
    <rdfs:label xml:lang="en">Country</rdfs:label>
    <rdfs:comment xml:lang="en">A sovereign country where a financial institution operates or has portfolio exposure.</rdfs:comment>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#Brazil">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Country"/>
    <rdfs:label xml:lang="en">Brazil</rdfs:label>
    <rdfs:comment xml:lang="en">Most megadiverse country globally, hosting 15-20% of world biodiversity across 6 biomes. Site of CEBDS TNFD pilot.</rdfs:comment>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#Organization">
    <rdfs:label xml:lang="en">Organization</rdfs:label>
    <rdfs:comment xml:lang="en">An organization that applies one or more biodiversity risk disclosure frameworks to assess its nature-related dependencies, impacts, risks and opportunities.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://schema.org/Organization"/>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#SemanticAmbiguity">
    <rdfs:label xml:lang="en">Semantic Ambiguity</rdfs:label>
    <rdfs:comment xml:lang="en">A documented case of semantic ambiguity in the correspondence between two industrial classification standards, where a category in one standard maps to multiple non-equivalent categories in another, or vice versa.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#DisclosureFramework">
    <rdfs:label xml:lang="en">Disclosure Framework</rdfs:label>
    <rdfs:comment xml:lang="en">A regulatory or voluntary framework requiring organisations to assess and disclose their nature-related impacts, dependencies, risks and opportunities.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#ESRSMaterialImpactDependency">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#FrameworkConcept"/>
    <rdfs:label xml:lang="en">ESRS E4 Material Impacts and Dependencies</rdfs:label>
    <rdfs:comment xml:lang="en">ESRS E4 disclosure of material impacts on biodiversity and material dependencies on ecosystem services, assessed under double materiality.</rdfs:comment>
    <bro:definedBy rdf:resource="https://w3id.org/biodivrisK-onto#ESRS_E4"/>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#FinancialInstitution">
    <rdfs:subClassOf rdf:resource="https://w3id.org/biodivrisK-onto#Organization"/>
    <rdfs:subClassOf rdf:resource="https://schema.org/BankOrCreditUnion"/>
    <rdfs:label xml:lang="en">Financial Institution</rdfs:label>
    <rdfs:comment xml:lang="en">A bank, investment fund, insurance company or other financial institution whose portfolio exposure to nature-related risks is assessed through biodiversity risk frameworks.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#LEAPAssessment">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
    <rdfs:label xml:lang="en">LEAP Assessment</rdfs:label>
    <rdfs:comment xml:lang="en">A structured assessment following the TNFD LEAP methodology (Locate, Evaluate, Assess, Prepare), conducted by an organization to identify and assess its nature-related dependencies, impacts, risks and opportunities. Connects the organization, frameworks applied, sectors evaluated, biomes, data sources and gaps identified.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#DataGap">
    <rdfs:label xml:lang="en">Data Gap</rdfs:label>
    <rdfs:comment xml:lang="en">A systematic absence or insufficiency of biodiversity occurrence data limiting the reliability of framework-based risk assessments in a given geographic area, taxonomic group or ecosystem type.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#DataSufficiencyAssessment">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
    <rdfs:label xml:lang="en">Data Sufficiency Assessment</rdfs:label>
    <rdfs:comment xml:lang="en">An evaluation of whether available biodiversity data from sources such as GBIF and OBIS are sufficient to meet the information requirements of a given disclosure framework for a specific biome, sector and location. Quantifies data gaps arising from geographic and taxonomic sampling bias.</rdfs:comment>
  </owl:Class>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#MiningAndMetalsSector">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:label xml:lang="en">Mining and Metals Sector</rdfs:label>
    <skos:altLabel xml:lang="en">Materials (GICS)</skos:altLabel>
    <bro:hasSectorClassification rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:assessedUnder rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="https://w3id.org/biodivrisK-onto#AgriculturalProductsSector">
    <rdf:type rdf:resource="https://w3id.org/biodivrisK-onto#Sector"/>
    <rdfs:label xml:lang="en">Agricultural Products Sector</rdfs:label>
    <bro:hasSectorClassification rdf:resource="https://w3id.org/biodivrisK-onto#GICS"/>
    <bro:assessedUnder rdf:resource="https://w3id.org/biodivrisK-onto#TNFD"/>
  </owl:NamedIndividual>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#InformationLoss">
    <rdfs:label xml:lang="en">Information Loss</rdfs:label>
    <rdfs:comment xml:lang="en">The loss of material information that occurs when translating a disclosure or target from one framework to another under an incommensurability relationship. Complements bro:hasBridgingCondition by documenting what is lost, not just under what conditions the conversion is admissible.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/biodivrisK-onto#MaterialityBoundary">
    <rdfs:label xml:lang="en">Materiality Boundary</rdfs:label>
    <rdfs:comment xml:lang="en">The scope and criteria used by a framework to determine which impacts and financial effects are material and must be disclosed.</rdfs:comment>
  </owl:Class>
</rdf:RDF>
