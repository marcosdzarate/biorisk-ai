@prefix : <https://w3id.org/biodivrisK-onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/biodivrisK-onto#> .

<https://w3id.org/biodivrisK-onto> rdf:type owl:Ontology ;
                                    owl:versionIRI <https://w3id.org/biodivrisK-onto/0.1.0> ;
                                    <http://purl.org/dc/terms/created> "2026-07-13"^^xsd:date ;
                                    <http://purl.org/dc/terms/creator> _:genid1 ;
                                    <http://purl.org/dc/terms/description> "BiodivRisk-Onto provides a formal OWL 2 DL representation of the semantic relations between four international biodiversity risk disclosure frameworks — TNFD, CSRD/ESRS E4, SBTN and GRI 101 — with particular attention to the data gaps arising from GBIF/OBIS sampling bias in Latin America and the Caribbean (LAC)."@en ;
                                    <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                    <http://purl.org/dc/terms/title> "BiodivRisk-Onto: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks"@en ;
                                    <http://purl.org/vocab/vann/preferredNamespacePrefix> "bro" ;
                                    <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/biodivrisK-onto#" ;
                                    rdfs:comment "Prototype v0.1.0. Developed as part of the paper submitted to AMW 2026."@en ;
                                    rdfs:seeAlso <https://github.com/marcosdzarate/biorisk-ai> ;
                                    owl:versionInfo "0.1.0" .

_:genid1 rdf:type <https://schema.org/Person> ;
          <https://schema.org/affiliation> "CESIMAR-CONICET, Puerto Madryn, Argentina" ;
          <https://schema.org/name> "Marcos Daniel Zárate" ;
          <https://schema.org/url> <https://orcid.org/0000-0001-8851-8602> .

