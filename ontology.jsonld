}, {
  "@id" : "https://schema.org/Person",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "https://schema.org/affiliation",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://schema.org/name",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://schema.org/url",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-07-13"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "_:genid1"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "BiodivRisk-Onto provides a formal OWL 2 DL representation of the semantic relations between four international biodiversity risk disclosure frameworks — TNFD, CSRD/ESRS E4, SBTN and GRI 101 — with particular attention to the data gaps arising from GBIF/OBIS sampling bias in Latin America and the Caribbean (LAC)."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "BiodivRisk-Onto: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "bro"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://w3id.org/biodivrisK-onto#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Prototype v0.1.0. Developed as part of the paper submitted to AMW 2026."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://github.com/marcosdzarate/biorisk-ai"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto/0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.1.0"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#DataGap",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A systematic absence or insufficiency of biodiversity occurrence data limiting the reliability of framework-based risk assessments in a given geographic area, taxonomic group or ecosystem type."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Data Gap"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A regulatory or voluntary framework requiring organisations to assess and disclose their nature-related impacts, dependencies, risks and opportunities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Disclosure Framework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#ESRSBiodiversitySensitiveArea",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Areas designated for biodiversity protection under ESRS E4, including Natura 2000 sites, UNESCO World Heritage, KBAs, and IUCN Category I–IV protected areas."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 Biodiversity-sensitive Area"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFDPriorityLocation"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 biodiversity-sensitive areas are a strict subset of TNFD priority locations. TNFD additionally covers rapid ecosystem decline and high water stress sites absent from the ESRS definition. Treating as equivalent produces false negatives in LAC screening."
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#ESRSDoubleMateriality",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 double materiality: an issue is material if it has significant impacts on biodiversity (impact materiality) OR poses financial risks/opportunities (financial materiality)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 Double Materiality"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#MaterialityBoundary"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 double materiality requires assessment of both impact and financial dimensions. TNFD applies single enterprise-value materiality. The two boundaries define different populations of disclosable items; thresholds are not interchangeable."
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ],
  "https://w3id.org/biodivrisK-onto#hasBridgingCondition" : [ {
    "@language" : "en",
    "@value" : "A lossy approximation is admissible if the analyst explicitly assumes that impact-material issues under ESRS E4 are also financially material under TNFD, and documents this assumption with supporting evidence. Does not hold by default."
  } ],
  "https://w3id.org/biodivrisK-onto#incommensurableWith" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#ESRSLandUseDatapoint",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 datapoint requiring disclosure of land-use change in hectares attributable to the undertaking's own operations and value chain."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 Land-use Change Datapoint"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Metric"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFDLandUseChangeMetric"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ],
  "https://w3id.org/biodivrisK-onto#unit" : [ {
    "@language" : "en",
    "@value" : "hectares (ha)"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#ESRSMaterialImpactDependency",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 disclosure of material impacts on biodiversity and material dependencies on ecosystem services, assessed under double materiality."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "ESRS E4 Material Impacts and Dependencies"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFDImpactDependency"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CSRD/ESRS E4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "European Sustainability Reporting Standard on Biodiversity and Ecosystems"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://www.efrag.org"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A concept, disclosure requirement, indicator or metric defined within a disclosure framework. Subclasses represent specific concepts; individuals of this class are not intended."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Framework Concept"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#GRI101",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GRI 101"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "GRI 101: Biodiversity Standard 2024"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://www.globalreporting.org"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#GRIImpactMateriality",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "GRI impact-only materiality: issues are material based on significance of actual or potential impacts on people and environment, regardless of financial consequences."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GRI Impact Materiality"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#MaterialityBoundary"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRI101"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#GRIManagementApproach",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "GRI 101 qualitative disclosure describing how an organisation manages its biodiversity impacts, policies, commitments and actions. No quantitative target required."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GRI 101 Management Approach"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "GRI 101 management approach disclosures compose with TNFD nature-related risk narratives. Impact reporting under GRI informs but does not replace risk framing under TNFD."
  } ],
  "https://w3id.org/biodivrisK-onto#complements" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFDImpactDependency"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRI101"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#GRIOperationsAdjacentProtectedAreas",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "GRI 101 disclosure of operations located in, adjacent to, or containing protected areas or Key Biodiversity Areas."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "GRI 101 Operations in/adjacent to Protected Areas and KBAs"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFDPriorityLocation"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "GRI 101 protected-area and KBA sites are a subset of TNFD areas of importance for biodiversity. TNFD applies a broader definition additionally covering areas of high biodiversity intactness beyond formal protection status."
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRI101"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#GeographicSamplingBias",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Systematic under-representation of species occurrences in GBIF/OBIS records for specific geographic regions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Geographic Sampling Bias"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DataGap"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#LACGeographicBias",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GeographicSamplingBias"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Systematic under-sampling of GBIF and OBIS records for key LAC biomes including the tropical Andes, Amazonia, the Cerrado and Caribbean marine ecosystems. Leads to false negatives in TNFD priority-location and ESRS E4 sensitive-area proximity screening."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "LAC Geographic Sampling Bias"
  } ],
  "https://w3id.org/biodivrisK-onto#affectsFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#GRI101"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#MaterialityBoundary",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The scope and criteria used by a framework to determine which impacts and financial effects are material and must be disclosed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Materiality Boundary"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Metric",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A quantitative or semi-quantitative indicator expressed in specific units or using a defined measurement approach."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Metric"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTN",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Science Based Targets Network for Nature"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://sciencebasedtargetsnetwork.org"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTNAR3TTarget",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Measurable, time-bound target following the SBTN AR3T hierarchy: Avoid, Reduce, Restore, Transform."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN Science-based Target (AR3T)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "An SBTN science-based target is measurable, time-bound and grounded in scientific baselines. A GRI 101 management approach describes intent without required quantification. Different epistemic status: verifiable outcome commitment vs description of policy intent."
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  } ],
  "https://w3id.org/biodivrisK-onto#hasBridgingCondition" : [ {
    "@language" : "en",
    "@value" : "A lossy approximation is admissible only if the GRI management approach explicitly commits to SBTN-compatible measurable targets with defined timelines and science-based baselines, AND those commitments are independently verified."
  } ],
  "https://w3id.org/biodivrisK-onto#incommensurableWith" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRIManagementApproach"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTNMeanSpeciesAbundance",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "State-of-nature metric measuring biodiversity intactness as the average abundance of originally present species relative to their abundance in undisturbed ecosystems (GLOBIO model)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN Mean Species Abundance (MSA)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Metric"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "MSA is a composite quantitative index measuring biodiversity intactness as a ratio. GRI 101 management approach is a qualitative policy disclosure with no implied biodiversity-state outcome. Different epistemic levels: state measurement vs organisational intent."
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  } ],
  "https://w3id.org/biodivrisK-onto#hasBridgingCondition" : [ {
    "@language" : "en",
    "@value" : "No direct conversion exists. A lossy approximation requires deriving a proxy MSA from operational footprint data AND documenting that the GRI management approach implies no specific biodiversity-state outcome. Not recommended for regulatory compliance."
  } ],
  "https://w3id.org/biodivrisK-onto#incommensurableWith" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRIManagementApproach"
  } ],
  "https://w3id.org/biodivrisK-onto#unit" : [ {
    "@language" : "en",
    "@value" : "dimensionless ratio (0–1)"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFD",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Taskforce on Nature-related Financial Disclosures"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://tnfd.global"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "TNFD single (enterprise-value) materiality: an issue is material if it poses financial risks or opportunities to the reporting organisation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Enterprise-value Materiality"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#MaterialityBoundary"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDImpactDependency",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Core TNFD concept requiring organisations to identify both their impacts on nature and their dependencies on ecosystem services."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Impacts and Dependencies on Nature"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Equivalence holds on the impact side only. Both classes share the ENCORE-derived logic of identifying organisational impacts on and dependencies upon nature. The financial materiality dimension of ESRS E4 double materiality has no direct equivalent in TNFD."
  }, {
    "@language" : "en",
    "@value" : "TNFD LEAP provides the assessment and disclosure process; SBTN AR3T provides science-based target-setting. SBTN targets feed into the TNFD strategy phase. Neither substitutes the other."
  } ],
  "https://w3id.org/biodivrisK-onto#complements" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDLandUseChangeMetric",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "TNFD core cross-sector metric measuring the extent (ha) of land, freshwater or ocean-use change."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Land/Freshwater/Ocean-use Change Metric"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Metric"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Equivalence holds because both classes measure the same physical quantity (land-use change in hectares) using the same unit. One of the rare genuine equivalences between the four frameworks."
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#unit" : [ {
    "@language" : "en",
    "@value" : "hectares (ha)"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDPriorityLocation",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Location of high importance for biodiversity under TNFD LEAP, including areas of high biodiversity intactness, protected areas, KBAs, areas of rapid ecosystem decline, and areas of high water stress."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Priority Location"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TaxonomicSamplingBias",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Systematic over-representation of certain taxonomic groups (e.g. birds, vascular plants) in open biodiversity databases."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Taxonomic Sampling Bias"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DataGap"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#affectsFramework",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a data gap to the framework(s) whose assessments are affected."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DataGap"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "affects framework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#complements",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Two framework concept classes that address distinct, jointly-required facets of one assessment. Licenses composition of evidence, not substitution. Symmetric."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "complements"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#definedBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a framework concept class to the framework that defines it."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "defined by"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#hasBridgingCondition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Documents the explicit assumption under which a lossy approximation between two incommensurable concepts is admissible. Required on every bro:incommensurableWith assertion."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has bridging condition"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#incommensurableWith",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Two framework concept classes for which no truth-preserving mapping exists due to different measurement units, materiality boundaries or epistemic commitments. Every assertion MUST carry bro:hasBridgingCondition. Symmetric."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "incommensurable with"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#unit",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Unit of measurement associated with a metric."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "unit"
  } ]
} ]