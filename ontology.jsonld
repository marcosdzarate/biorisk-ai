}, {
  "@id" : "https://w3id.org/biodivrisK-onto#InformationLoss",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The loss of material information that occurs when translating a disclosure or target from one framework to another under an incommensurability relationship. Complements bro:hasBridgingCondition by documenting what is lost, not just under what conditions the conversion is admissible."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Information Loss"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#InternalPolicy",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An organization's internal policy for managing environmental, social, climate or nature-related risks (e.g., an ESCC policy). May partially cover requirements of external disclosure frameworks."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Internal Policy"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#ItauUnibanco",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FinancialInstitution"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Itaú Unibanco"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://www.itau.com.br"
  } ],
  "https://w3id.org/biodivrisK-onto#appliesFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#operatesInCountry" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Brazil"
  } ],
  "https://w3id.org/biodivrisK-onto#usesClassification" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#CNAE"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#LACGeographicBias",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GeographicSamplingBias"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Systematic under-sampling of GBIF and OBIS records for key LAC biomes including the tropical Andes, Amazonia, the Cerrado and Caribbean marine ecosystems. Leads to false negatives in TNFD priority-location and ESRS E4 sensitive-area proximity screening."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "LAC Geographic Sampling Bias"
  } ],
  "https://w3id.org/biodivrisK-onto#affectsFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#GRI101"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#LEAPAssessment",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A structured assessment following the TNFD LEAP methodology (Locate, Evaluate, Assess, Prepare), conducted by an organization to identify and assess its nature-related dependencies, impacts, risks and opportunities. Connects the organization, frameworks applied, sectors evaluated, biomes, data sources and gaps identified."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "LEAP Assessment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Activity"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#MaterialityApproach",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A methodological approach for determining which nature-related impacts, risks and opportunities are material and must be disclosed. Different frameworks apply different approaches (financial, impact, or double materiality) that are not mutually equivalent."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Materiality Approach"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#MaterialityBoundary",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The scope and criteria used by a framework to determine which impacts and financial effects are material and must be disclosed."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Materiality Boundary"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#MaterialityResult",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The output of a materiality assessment — a ranked or scored set of sectors, locations or impacts identified as material under a specific framework and approach."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Materiality Result"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Metric",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A quantitative or semi-quantitative indicator expressed in specific units or using a defined measurement approach."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Metric"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#MiningAndMetalsSector",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Sector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Mining and Metals Sector"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Materials (GICS)"
  } ],
  "https://w3id.org/biodivrisK-onto#assessedUnder" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#hasSectorClassification" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GICS"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#OBISData",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#BiodiversityDataSource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Ocean Biodiversity Information System — primary open source for marine species occurrence records. Under-representation of Caribbean marine ecosystems."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "OBIS Marine Data"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://obis.org"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Organization",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An organization that applies one or more biodiversity risk disclosure frameworks to assess its nature-related dependencies, impacts, risks and opportunities."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Organization"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://schema.org/Organization"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Peru",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Country"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Megadiverse country — one of 17 globally. Second largest copper producer worldwide. High Andean and Amazonian biodiversity with documented GBIF sampling gaps."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Peru"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#PhysicalRisk",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A nature-related physical risk arising from the degradation of ecosystems or natural capital, including water stress, ecosystem collapse, loss of pollination, erosion or flooding. Corresponds to TNFD and ESRS physical risk category."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Physical Risk"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Portfolio",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A credit or investment portfolio of a financial institution, composed of assets across multiple economic sectors and geographic locations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Portfolio"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#PriorityLocation",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A geographic location identified as high-priority for biodiversity assessment under TNFD LEAP L4, based on five sensitive location criteria: (1) important for biodiversity; (2) high ecosystem integrity; (3) rapid ecosystem decline; (4) high physical water risk; (5) important for ecosystem services provision."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Priority Location"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#QualitativeMaterialityScale",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A narrative or categorical approach to assessing materiality of nature-related impacts, without a fixed numerical scale (e.g., GRI 101 impact materiality approach)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Qualitative Materiality Scale"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#MaterialityApproach"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#QuantitativeMaterialityScale",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A numerical scale used to score materiality of nature-related impacts and dependencies (e.g., ENCORE scale 3-9: very low=3, low=4.5, medium=6, high=7.5, very high=9)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Quantitative Materiality Scale"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#MaterialityApproach"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SASB_SICS",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#IndustrialClassification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SASB SICS"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "SASB Sustainable Industry Classification System"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTN",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Science Based Targets Network for Nature"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://sciencebasedtargetsnetwork.org"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTNAR3TTarget",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Measurable, time-bound target following the SBTN AR3T hierarchy: Avoid, Reduce, Restore, Transform."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN Science-based Target (AR3T)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "An SBTN science-based target is measurable, time-bound and grounded in scientific baselines. A GRI 101 management approach describes intent without required quantification. Different epistemic status: verifiable outcome commitment vs description of policy intent."
  } ],
  "https://w3id.org/biodivrisK-onto#coveredByFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  } ],
  "https://w3id.org/biodivrisK-onto#hasBridgingCondition" : [ {
    "@language" : "en",
    "@value" : "A lossy approximation is admissible only if the GRI management approach explicitly commits to SBTN-compatible measurable targets with defined timelines and science-based baselines, AND those commitments are independently verified."
  } ],
  "https://w3id.org/biodivrisK-onto#incommensurableWith" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRIManagementApproach"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTNAR3TTargetInstance",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A science-based target following the SBTN AR3T hierarchy (Avoid, Reduce, Restore, Transform), as applicable to financial institutions assessing their portfolio exposure to nature loss. Requires LEAP assessment outputs as input for geographic and sectoral target-setting."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN AR3T Science-based Target"
  } ],
  "https://w3id.org/biodivrisK-onto#requiresInputFrom" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#CEBDSBrazilLocateAssessment"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#SantanderPeruL4Assessment"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTNMeanSpeciesAbundance",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "State-of-nature metric measuring biodiversity intactness as the average abundance of originally present species relative to their abundance in undisturbed ecosystems (GLOBIO model)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN Mean Species Abundance (MSA)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Metric"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "MSA is a composite quantitative index measuring biodiversity intactness as a ratio. GRI 101 management approach is a qualitative policy disclosure with no implied biodiversity-state outcome. Different epistemic levels: state measurement vs organisational intent."
  } ],
  "https://w3id.org/biodivrisK-onto#coveredByFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTN"
  } ],
  "https://w3id.org/biodivrisK-onto#hasBridgingCondition" : [ {
    "@language" : "en",
    "@value" : "No direct conversion exists. A lossy approximation requires deriving a proxy MSA from operational footprint data AND documenting that the GRI management approach implies no specific biodiversity-state outcome. Not recommended for regulatory compliance."
  } ],
  "https://w3id.org/biodivrisK-onto#incommensurableWith" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRIManagementApproach"
  } ],
  "https://w3id.org/biodivrisK-onto#unit" : [ {
    "@language" : "en",
    "@value" : "dimensionless ratio (0–1)"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SBTNtargetToGRIConversion",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#InformationLoss"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Information loss documented when converting an SBTN science-based target (measurable, time-bound, science-grounded) to a GRI 101 management approach disclosure (qualitative, policy-level). Lost information includes: (1) quantitative target value, (2) scientific baseline, (3) time horizon commitment, (4) verifiability. Bridging condition: the GRI management approach must explicitly commit to SBTN-compatible targets with verified science-based baselines."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "SBTN Target to GRI Management Approach Conversion"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SantanderBrasil",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FinancialInstitution"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Santander Brasil"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://www.santander.com.br"
  } ],
  "https://w3id.org/biodivrisK-onto#appliesFramework" : [ {
