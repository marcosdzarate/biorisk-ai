  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Sector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Agricultural Products Sector"
  } ],
  "https://w3id.org/biodivrisK-onto#assessedUnder" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#hasSectorClassification" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GICS"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Amazonia",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Biome"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Largest tropical rainforest biome globally. Under-sampled in GBIF particularly for invertebrates and cryptic taxa. Relevant to both Santander Peru and CEBDS Brazil cases."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Amazonia Biome"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#AndeanDataGap",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GeographicSamplingBias"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Documented under-sampling of species occurrence records in GBIF for the tropical Andes biome, including Peru. Bias towards roads, cities and protected area boundaries. Leads to false negatives in TNFD priority-location screening. Empirically documented in Santander Peru LEAP L3-L4 assessment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Andean GBIF Data Gap"
  } ],
  "https://w3id.org/biodivrisK-onto#affectsFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#AndeanWaterStressRisk",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#WaterStressRisk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Physical risk from insufficient freshwater availability in Andean mining and agricultural operations in Peru. Identified as a material dependency in Santander Peru LEAP L2: groundwater use and protection against flooding were the most material ecosystem service dependencies. High water stress zones identified via WRI Aqueduct in LEAP L4."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Andean Water Stress Risk"
  } ],
  "https://w3id.org/biodivrisK-onto#affectsRiskAssessment" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#AtlanticForest",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Biome"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Critical biodiversity hotspot — less than 29% of original cover remains. Among the most threatened biomes in the world. Relevant to CEBDS Brazil case."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Atlantic Forest Biome"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "pt",
    "@value" : "Mata Atlântica"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#BNDES",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FinancialInstitution"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BNDES"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Banco Nacional de Desenvolvimento Econômico e Social"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://www.bndes.gov.br"
  } ],
  "https://w3id.org/biodivrisK-onto#appliesFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#operatesInCountry" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Brazil"
  } ],
  "https://w3id.org/biodivrisK-onto#usesClassification" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#CNAE"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#BiodiversityDataSource",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An open or proprietary data source used to obtain species occurrence, ecosystem integrity or water risk data during a LEAP assessment (e.g., GBIF, OBIS, ENCORE, Global Forest Watch, WRI Aqueduct, IBAT)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Biodiversity Data Source"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Biome",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A major ecological zone characterized by distinctive climate, vegetation and biodiversity. Reuses ENVO biome concept (ENVO:00000428). In LAC, biomes are megadiverse and systematically under-sampled in GBIF/OBIS."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Biome"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Bradesco",
