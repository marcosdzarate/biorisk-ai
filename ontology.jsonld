}, {
  "@id" : "https://w3id.org/biodivrisK-onto",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-07-13"
  }, {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-07-21"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "_:genid1"
  }, {
    "@id" : "_:genid2"
  }, {
    "@id" : "_:genid3"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "BiodivRisk-Onto provides a formal OWL 2 DL representation of the semantic relations between four international biodiversity risk disclosure frameworks — TNFD, CSRD/ESRS E4, SBTN and GRI 101 — with particular attention to the data gaps arising from GBIF/OBIS sampling bias in Latin America and the Caribbean (LAC)."
  }, {
    "@language" : "en",
    "@value" : "Extension of v0.1.0 with organizational, geographic, and evaluation modules, populated with real-world instances from the Santander Peru and CEBDS Brazil case studies."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "BiodivRisk-Onto v0.2.0: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks"
  }, {
    "@language" : "en",
    "@value" : "BiodivRisk-Onto: An Ontology for Semantic Alignment of Biodiversity Risk Disclosure Frameworks"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "bro"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://w3id.org/biodivrisK-onto#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Prototype v0.1.0. Developed as part of the paper submitted to AMW 2026."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://github.com/marcosdzarate/biorisk-ai"
  }, {
    "@id" : "https://github.com/marcosdzarate/biorisk-ai/tree/main/ontology"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto/0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto/0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.1.0"
  }, {
    "@value" : "0.2.0"
  } ]
