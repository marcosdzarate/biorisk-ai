  } ],
  "https://w3id.org/biodivrisK-onto#requiresDataFrom" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ENCOREData"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#GlobalForestWatchData"
  }, {
    "@id" : "https://w3id.org/biodivrisK-onto#WRIAqueductData"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#Sector",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An economic sector associated with potential impacts and dependencies on nature, classifiable under international standards such as GICS or SASB/SICS."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Economic Sector"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SemanticAmbiguity",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A documented case of semantic ambiguity in the correspondence between two industrial classification standards, where a category in one standard maps to multiple non-equivalent categories in another, or vice versa."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Semantic Ambiguity"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFD",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Taskforce on Nature-related Financial Disclosures"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://tnfd.global"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDEnterpriseMateriality",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "TNFD single (enterprise-value) materiality: an issue is material if it poses financial risks or opportunities to the reporting organisation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Enterprise-value Materiality"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#MaterialityBoundary"
  } ],
  "https://w3id.org/biodivrisK-onto#coveredByFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#incommensurableWith" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRSDoubleMateriality"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDImpactDependency",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Core TNFD concept requiring organisations to identify both their impacts on nature and their dependencies on ecosystem services."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Impacts and Dependencies on Nature"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Equivalence holds on the impact side only. Both classes share the ENCORE-derived logic of identifying organisational impacts on and dependencies upon nature. The financial materiality dimension of ESRS E4 double materiality has no direct equivalent in TNFD."
  }, {
    "@language" : "en",
    "@value" : "TNFD LEAP provides the assessment and disclosure process; SBTN AR3T provides science-based target-setting. SBTN targets feed into the TNFD strategy phase. Neither substitutes the other."
  } ],
  "https://w3id.org/biodivrisK-onto#complements" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SBTNAR3TTarget"
  } ],
  "https://w3id.org/biodivrisK-onto#coveredByFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDLandUseChangeMetric",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "TNFD core cross-sector metric measuring the extent (ha) of land, freshwater or ocean-use change."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Land/Freshwater/Ocean-use Change Metric"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Metric"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Equivalence holds because both classes measure the same physical quantity (land-use change in hectares) using the same unit. One of the rare genuine equivalences between the four frameworks."
  } ],
  "https://w3id.org/biodivrisK-onto#coveredByFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#unit" : [ {
    "@language" : "en",
    "@value" : "hectares (ha)"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDPriorityLocation",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Location of high importance for biodiversity under TNFD LEAP, including areas of high biodiversity intactness, protected areas, KBAs, areas of rapid ecosystem decline, and areas of high water stress."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Priority Location"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "https://w3id.org/biodivrisK-onto#coveredByFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#ESRS_E4"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TNFDStrategyD",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureRequirement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "TNFD recommended disclosure Strategy D: disclose the locations of assets and/or activities in direct operations and, where possible, upstream and downstream value chains that meet the criteria for priority locations."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "TNFD Strategy D"
  } ],
  "https://w3id.org/biodivrisK-onto#definedBy" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TaxonomicSamplingBias",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Systematic over-representation of certain taxonomic groups (e.g. birds, vascular plants) in open biodiversity databases."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Taxonomic Sampling Bias"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DataGap"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#TropicalAndes",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Biome"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Biodiversity hotspot in the Andes mountains of Peru, Colombia, Ecuador and Bolivia. Under-sampled in GBIF: occurrence records biased towards roads and urban areas, with insufficient coverage of high-altitude species."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tropical Andes Biome"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#UtilitiesSector",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Sector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Utilities Sector"
  } ],
  "https://w3id.org/biodivrisK-onto#assessedUnder" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#hasSectorClassification" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GICS"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#WRIAqueductData",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#BiodiversityDataSource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "World Resources Institute water risk atlas — used in LEAP L4 to identify high physical water stress zones. Used by both case study institutions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "WRI Aqueduct"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://www.wri.org/aqueduct"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#WaterStressRisk",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Physical risk arising from insufficient availability or quality of freshwater resources, particularly relevant for mining and agricultural sectors in the Andes. Identified as material dependency in the Santander Peru LEAP assessment (L2)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Water Stress Risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#PhysicalRisk"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#affectsFramework",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a data gap to the framework(s) whose assessments are affected."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DataGap"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "affects framework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#affectsRiskAssessment",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a materiality boundary gap to the type of physical risk whose assessment is affected."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#MaterialityBoundary"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "affects risk assessment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#PhysicalRisk"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#appliesFramework",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates an organization to a disclosure framework it applies or is subject to."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Organization"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "applies framework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#assessedUnder",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a sector or portfolio to the disclosure framework under which it was assessed for materiality."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Sector"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "assessed under"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#complements",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Two framework concept classes that address distinct, jointly-required facets of one assessment. Licenses composition of evidence, not substitution. Symmetric."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "complements"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Class"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#coveredByFramework",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a framework concept to the frameworks that include or address it."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "covered by framework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#coversRequirement",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates an internal policy to the disclosure requirements of external frameworks that it partially or fully covers."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#InternalPolicy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "covers requirement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureRequirement"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#definedBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a framework concept class to the framework that defines it."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#FrameworkConcept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "defined by"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#hasAmbiguity",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#IndustrialClassification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has ambiguity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#SemanticAmbiguity"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#hasBridgingCondition",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Documents the explicit assumption under which a lossy approximation between two incommensurable concepts is admissible. Required on every bro:incommensurableWith assertion."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has bridging condition"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#hasDataGapIn",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Relates a disclosure framework to a biome where its data requirements cannot be met due to GBIF/OBIS sampling bias."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#DisclosureFramework"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has data gap in"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#Biome"
