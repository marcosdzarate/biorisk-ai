  } ],
  "https://w3id.org/biodivrisK-onto#usesClassification" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#CNAE"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SantanderPeru",
