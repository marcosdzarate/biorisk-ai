    "@id" : "https://w3id.org/biodivrisK-onto#FinancialInstitution"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Banco Bradesco"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://www.bradesco.com.br"
  } ],
  "https://w3id.org/biodivrisK-onto#appliesFramework" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#TNFD"
  } ],
  "https://w3id.org/biodivrisK-onto#operatesInCountry" : [ {
