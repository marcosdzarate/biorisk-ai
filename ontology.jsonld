  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Santander Peru's Environmental, Social, Climate and Compliance (ESCC) risk management policy. Covers IUCN protected areas and Ramsar sites but does not extend to all TNFD sensitive location criteria (rapid ecosystem decline, high water stress)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Santander Peru ESCC Risk Policy"
  } ],
  "https://w3id.org/biodivrisK-onto#coversRequirement" : [ {
    "@id" : "https://w3id.org/biodivrisK-onto#GRIProtectedAreaKBA"
  } ]
}, {
  "@id" : "https://w3id.org/biodivrisK-onto#SantanderPeruL4Assessment",
